---
import "../styles/global.css";
import { withBase } from "../utils/paths";

const {
  lang = "en",
  title = "PrintForge",
  description = "",
  canonical = "",
  ogImage = "/og-en.svg",
  hreflang = { tr: "/tr/", en: "/en/" },
  noindex = false,
} = Astro.props;

const site = (Astro.site?.toString() ?? "https://example.com").replace(/\/$/, "");
const base = import.meta.env.BASE_URL ?? "/";

const canonicalPath = canonical
  ? (canonical.startsWith("http") ? canonical : withBase(canonical, base))
  : withBase(Astro.url.pathname, base);

const canonicalUrl = canonicalPath.startsWith("http") ? canonicalPath : site + canonicalPath;

const ogPath = ogImage.startsWith("http") ? ogImage : withBase(ogImage, base);
const ogUrl = ogPath.startsWith("http") ? ogPath : site + ogPath;

const trHref = site + withBase(hreflang.tr, base);
const enHref = site + withBase(hreflang.en, base);
const xDefaultHref = site + withBase("/", base);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "PrintForge",
  "applicationCategory": "DesignApplication",
  "operatingSystem": "Web",
  "description": description,
  "url": canonicalUrl
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href={withBase("/favicon.svg", base)} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogUrl} />

    <link rel="alternate" hreflang="tr" href={trHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <script type="application/ld+json">{JSON.stringify(jsonLd)}</script>
  </head>
  <body>
    <slot />
  </body>
</html>
