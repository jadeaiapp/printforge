    ---
    import BaseLayout from "../../layouts/BaseLayout.astro";
    import Topbar from "../../components/Topbar.astro";
    import HeroMock from "../../components/HeroMock.astro";
    import CTA from "../../components/CTA.astro";

    const labels = {"navFeatures": "Özellikler", "navHow": "Nasıl çalışır?", "navFaq": "SSS", "langSwitch": "English", "ctaPrimary": "Tasarlamaya başla", "heroKicker": "Sürükle‑bırak printable tasarım aracı", "heroTitle": "Baskıda net görünen printables tasarla.", "heroLead": "A4/A5 için profesyonel bir tuval: blokları istediğin yere bırak, sayfaları çoğalt, keskin PDF export al. Ücretsiz başla—hesap gerekmez.", "heroPrimary": "Builder’ı aç", "heroSecondary": "Özelliklere bak", "featTitle": "Printable iş akışları için üretildi", "featLead": "Planner, worksheet, tracker ve çok sayfalı setler için gereken her şey—tam bir tasarım paketinin karmaşası olmadan.", "features": [["Serbest tuval", "Her şeyi istediğin yere koy. Snap/align ile milimetre hassasiyet."], ["Çok sayfalı doküman", "Sayfa ekle, çoğalt, sırala. Tek PDF olarak export."], ["Baskıya hazır export", "A4/A5, margin ve temiz vektörel PDF çıktısı."], ["Blok kütüphanesi", "Metin, kutu, çizgi, checklist, tablo, takvim, tracker."], ["Pro edit deneyimi", "Undo/redo, kısayollar, layer, grouping (roadmap)."], ["Offline-first MVP", "Statik web app gibi çalışır; projeyi JSON olarak kaydedebilirsin."]], "howTitle": "Nasıl çalışır?", "howLead": "Basit, hızlı ve kontrol sende.", "steps": [["Tuvali aç", "Boştan başla veya preset seç; A4/A5 belirle."], ["Sayfalarını kur", "Blokları sürükle, stilini ayarla, sayfa çoğalt."], ["Export & paylaş", "Keskin PDF indir veya proje dosyanı kaydet."]], "faqTitle": "SSS", "faq": [["Hesap gerekiyor mu?", "v1’de hayır. v2’de günlük kota ve bulut kayıt için email login ekleyeceğiz."], ["Sadece planner mı?", "Hayır. Her türlü printable: worksheet, bingo, tracker, checklist, etiket."], ["Mobilde çalışır mı?", "Evet; ama en iyi edit deneyimi desktop/tablet. Mobil preview/export için iyi."], ["Fiyatlandırma nasıl olacak?", "Ücretsiz başla. Sonra: login zorunlu günlük kota + daha yüksek limitli ücretli plan."]], "ctaTitle": "İlk printable’ını tasarlamaya hazır mısın?", "ctaBody": "Builder’ı aç ve dakikalar içinde baskıya hazır PDF al.", "footerNote": "© {year} PrintForge. Printables için üretildi."};
    const title = "PrintForge — Sürükle‑bırak printable tasarım aracı";
    const description = "A4/A5 için profesyonel bir tuval: blokları istediğin yere bırak, sayfaları çoğalt, keskin PDF export al. Ücretsiz başla—hesap gerekmez.";
    ---
    <BaseLayout lang="tr" title={title} description={description} canonical="/tr/" ogImage="/og-tr.svg" hreflang={tr:"/tr/", en:"/en/"}>
      <Topbar lang="tr" labels={labels} switcherHref="/en/" />

      <main>
        <div class="container hero" id="top">
          <div class="hero-grid">
            <div>
              <div class="kicker">Sürükle‑bırak printable tasarım aracı</div>
              <h1>Baskıda net görünen printables tasarla.</h1>
              <p class="lead">A4/A5 için profesyonel bir tuval: blokları istediğin yere bırak, sayfaları çoğalt, keskin PDF export al. Ücretsiz başla—hesap gerekmez.</p>

              <div class="hero-cta">
                <a class="btn primary" href="/app/">Builder’ı aç</a>
                <a class="btn" href="#features">Özelliklere bak</a>
              </div>

              <div style="margin-top:18px;color:rgba(229,231,235,0.65);font-size:13px;">
                Kurulum yok • Hesap yok • Export hazır
              </div>
            </div>

            <HeroMock />
          </div>
        </div>

        <section id="features">
          <div class="container">
            <h2 class="section-title">Printable iş akışları için üretildi</h2>
            <p class="section-lead">Planner, worksheet, tracker ve çok sayfalı setler için gereken her şey—tam bir tasarım paketinin karmaşası olmadan.</p>
            <div class="grid-3">
              <div class="card"><h3>Serbest tuval</h3><p>Her şeyi istediğin yere koy. Snap/align ile milimetre hassasiyet.</p></div>
<div class="card"><h3>Çok sayfalı doküman</h3><p>Sayfa ekle, çoğalt, sırala. Tek PDF olarak export.</p></div>
<div class="card"><h3>Baskıya hazır export</h3><p>A4/A5, margin ve temiz vektörel PDF çıktısı.</p></div>
<div class="card"><h3>Blok kütüphanesi</h3><p>Metin, kutu, çizgi, checklist, tablo, takvim, tracker.</p></div>
<div class="card"><h3>Pro edit deneyimi</h3><p>Undo/redo, kısayollar, layer, grouping (roadmap).</p></div>
<div class="card"><h3>Offline-first MVP</h3><p>Statik web app gibi çalışır; projeyi JSON olarak kaydedebilirsin.</p></div>
            </div>
          </div>
        </section>

        <section id="how">
          <div class="container">
            <h2 class="section-title">Nasıl çalışır?</h2>
            <p class="section-lead">Basit, hızlı ve kontrol sende.</p>
            <div class="steps">
              <div class="step"><div class="num">1</div><h3 style="margin:0 0 8px;font-size:16px;">Tuvali aç</h3><p style="margin:0;color:var(--muted);font-size:14px;">Boştan başla veya preset seç; A4/A5 belirle.</p></div>
<div class="step"><div class="num">2</div><h3 style="margin:0 0 8px;font-size:16px;">Sayfalarını kur</h3><p style="margin:0;color:var(--muted);font-size:14px;">Blokları sürükle, stilini ayarla, sayfa çoğalt.</p></div>
<div class="step"><div class="num">3</div><h3 style="margin:0 0 8px;font-size:16px;">Export & paylaş</h3><p style="margin:0;color:var(--muted);font-size:14px;">Keskin PDF indir veya proje dosyanı kaydet.</p></div>
            </div>
          </div>
        </section>

        <section id="faq">
          <div class="container">
            <h2 class="section-title">SSS</h2>
            <p class="section-lead">Kısa cevaplar. Ürün geliştikçe güncelleyeceğiz.</p>
            <details><summary>Hesap gerekiyor mu?</summary><div style="margin-top:10px;color:var(--muted);font-size:14px;">v1’de hayır. v2’de günlük kota ve bulut kayıt için email login ekleyeceğiz.</div></details>
<details><summary>Sadece planner mı?</summary><div style="margin-top:10px;color:var(--muted);font-size:14px;">Hayır. Her türlü printable: worksheet, bingo, tracker, checklist, etiket.</div></details>
<details><summary>Mobilde çalışır mı?</summary><div style="margin-top:10px;color:var(--muted);font-size:14px;">Evet; ama en iyi edit deneyimi desktop/tablet. Mobil preview/export için iyi.</div></details>
<details><summary>Fiyatlandırma nasıl olacak?</summary><div style="margin-top:10px;color:var(--muted);font-size:14px;">Ücretsiz başla. Sonra: login zorunlu günlük kota + daha yüksek limitli ücretli plan.</div></details>
          </div>
        </section>

        <CTA
          title="İlk printable’ını tasarlamaya hazır mısın?"
          body="Builder’ı aç ve dakikalar içinde baskıya hazır PDF al."
          primary={ href: "/app/", label: labels.ctaPrimary }
          secondary={ href: "#top", label: ("Back to top" if lang=="en" else "Başa dön") }
        />

        <footer class="footer">
          <div class="container footer-grid">
            <div class="brand">
              <span class="brand-badge" aria-hidden="true">✦</span>
              <span>PrintForge</span>
            </div>
            <div class="tiny">© 2026 PrintForge. Printables için üretildi.</div>
          </div>
        </footer>
      </main>
    </BaseLayout>
