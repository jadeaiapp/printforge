---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/paths";

const base = import.meta.env.BASE_URL ?? "/";
const trPath = withBase("/tr/", base);
const enPath = withBase("/en/", base);
const title = "PrintForge — Printable Builder";
const description = "Redirecting to your preferred language landing page.";
---
<BaseLayout lang="en" title={title} description={description} canonical="/" ogImage="/og-en.svg" hreflang={{ tr: "/tr/", en: "/en/" }}>
  <div class="container" style="padding:90px 0 30px;">
    <div class="kicker">✦ PrintForge</div>
    <h1>Redirecting…</h1>
    <p class="lead">Choose a language if you are not redirected automatically.</p>
    <div class="hero-cta">
      <a class="btn primary" href={enPath}>English</a>
      <a class="btn" href={trPath}>Türkçe</a>
    </div>

    <noscript>
      <p class="tiny" style="margin-top:16px;">JavaScript is disabled. Continue manually:</p>
      <div class="hero-cta">
        <a class="btn primary" href={enPath}>English</a>
        <a class="btn" href={trPath}>Türkçe</a>
      </div>
    </noscript>
  </div>

  <script define:vars={{ trPath, enPath }}>
    (function () {
      const lang = (navigator.language || "").toLowerCase();
      const nextPath = lang.startsWith("tr") ? trPath : enPath;
      window.location.replace(nextPath);
    })();
  </script>
</BaseLayout>
