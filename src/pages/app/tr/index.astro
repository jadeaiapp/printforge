---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { withBase } from "../../../utils/paths";
import "../../../styles/app.css";
import labels from "../../../app/locales/tr";

const base = import.meta.env.BASE_URL ?? "/";
---
<BaseLayout lang="tr" title="PrintForge Uygulama" description="Etkileşimli baskı tasarım aracı" canonical="/app/tr/" ogImage="/og-tr.svg" hreflang={{ tr: "/app/tr/", en: "/app/" }} noindex={true}>
  <div class="app-shell" id="app-shell">
    <header class="app-topbar">
      <a class="brand" href={withBase("/tr/", base)}>
        <span class="brand-badge" aria-hidden="true">✦</span>
        <span>PrintForge</span>
      </a>
      <a class="btn ghost lang-switcher" href={withBase("/app/", base)}>{labels.langSwitch}</a>
      <button type="button" class="btn ghost btn-icon" id="shortcuts-btn" title={labels.shortcutsTitle} aria-label={labels.shortcutsTitle}>⌘</button>
      <button type="button" class="btn ghost btn-icon" id="tips-btn" title={labels.tipsTitle} aria-label={labels.tipsTitle}>?</button>
      <div class="top-controls">
        <label class="field inline project-name-field"><span>{labels.project}</span><input id="project-name" class="control" type="text" value={labels.untitledProject} maxlength="80" /></label>
        <label class="field inline"><span>{labels.zoom}</span>
          <select id="zoom-select" class="control"><option value="0.25">25%</option><option value="0.5">50%</option><option value="0.75">75%</option><option value="1" selected>100%</option><option value="fit">Fit</option><option value="fitSelection">{labels.fitSelection}</option></select>
        </label>
        <div class="segment" role="group" aria-label="Page size"><button type="button" data-size="A4" class="is-active">A4</button><button type="button" data-size="A5">A5</button></div>
        <div class="segment" role="group" aria-label="Page orientation"><button type="button" data-orientation="portrait" class="is-active">Portrait</button><button type="button" data-orientation="landscape">Landscape</button></div>

        <label class="checkline"><input type="checkbox" id="grid-toggle" /> {labels.grid}</label>
        <label class="checkline"><input type="checkbox" id="ruler-toggle" /> {labels.rulers}</label>
        <label class="checkline"><input type="checkbox" id="safe-area-toggle" /> {labels.safeArea}</label>
        <label class="field inline"><span>{labels.step}</span>
          <select id="grid-step" class="control"><option value="2">2mm</option><option value="5" selected>5mm</option><option value="10">10mm</option></select>
        </label>

        <span id="save-indicator" class="save-indicator" aria-live="polite">{labels.saved}</span>

        <button type="button" id="delete-btn" class="btn btn-danger" disabled>{labels.delete}</button>
        <details class="file-menu" id="file-menu">
          <summary class="btn btn-primary">{labels.file}</summary>
          <div class="file-menu-list" role="menu" aria-label="File actions">
            <button type="button" id="new-project-btn" class="file-menu-item" role="menuitem">{labels.newProject}</button>
            <button type="button" id="duplicate-project-btn" class="file-menu-item" role="menuitem">{labels.duplicateProject}</button>
            <button type="button" id="clear-project-btn" class="file-menu-item" role="menuitem">{labels.clearProject}</button>
            <button type="button" id="save-btn" class="file-menu-item" role="menuitem">{labels.saveLocal}</button>
            <button type="button" id="load-btn" class="file-menu-item" role="menuitem">{labels.loadLocal}</button>
            <button type="button" id="export-pdf-btn" class="file-menu-item" role="menuitem">{labels.exportPdf}</button>
            <button type="button" id="export-png-btn" class="file-menu-item" role="menuitem">{labels.exportPagePng}</button>
            <button type="button" id="export-btn" class="file-menu-item" role="menuitem">{labels.exportJson}</button>
            <button type="button" id="import-btn" class="file-menu-item" role="menuitem">{labels.importJson}</button>
            <button type="button" id="print-preview-btn" class="file-menu-item" role="menuitem">{labels.printPreview}</button>
            <button type="button" id="print-btn" class="file-menu-item" role="menuitem">{labels.print}</button>
            <div class="file-menu-recent">
              <strong>{labels.recentProjects}</strong>
              <div id="recent-projects" class="recent-projects-empty">{labels.noSnapshots}</div>
            </div>
          </div>
        </details>
        <input id="import-input" type="file" accept="application/json" hidden />
        <input id="image-input" type="file" accept="image/*" hidden />
      </div>
    </header>

    <main class="app-main">
      <aside class="panel left-panel">
        <div class="left-tabs" role="tablist" aria-label="Left panel tabs">
          <button type="button" class="left-tab is-active" id="tab-blocks" data-tab="blocks" role="tab" aria-selected="true">{labels.blocks}</button>
          <button type="button" class="left-tab" id="tab-layers" data-tab="layers" role="tab" aria-selected="false">{labels.layers}</button>
          <button type="button" class="left-tab" id="tab-assets" data-tab="assets" role="tab" aria-selected="false">{labels.assets}</button>
          <button type="button" class="left-tab" id="tab-theme" data-tab="theme" role="tab" aria-selected="false">{labels.theme}</button>
        </div>

        <div id="left-scroll" class="left-scroll">
          <section id="panel-blocks" class="tab-panel active" role="tabpanel" aria-labelledby="tab-blocks">
            <div id="block-list" class="block-list">
              <button class="block-item" data-block="text" draggable="true">🅣 Text</button>
              <button class="block-item" data-block="heading" draggable="true">Ⓗ Heading</button>
              <button class="block-item" data-block="paragraph" draggable="true">¶ Paragraph</button>
              <button class="block-item" data-block="checkbox" draggable="true">☑ Checkbox</button>
              <button class="block-item" data-block="checklist" draggable="true">☰ Checklist</button>
              <button class="block-item" data-block="bulletlist" draggable="true">• Bullet list</button>
              <button class="block-item" data-block="divider" draggable="true">─ Divider</button>
              <button class="block-item" data-block="highlight" draggable="true">▧ Highlight</button>
              <button class="block-item" data-block="circle" draggable="true">◯ Circle</button>
              <button class="block-item" data-block="roundedrect" draggable="true">▢ Rounded rect</button>
              <button class="block-item" data-block="datelabel" draggable="true">🗓 Date</button>
              <button class="block-item" data-block="table" draggable="true">▦ Table</button>
              <button class="block-item" data-block="calendar" draggable="true">📅 Calendar</button>
              <button class="block-item" data-block="image" draggable="true">🖼 Image</button>
              <button class="block-item" data-block="box" draggable="true">⬚ Box</button>
              <button class="block-item" data-block="line" draggable="true">⎯ Line</button>
            </div>
          </section>

          <section id="panel-layers" class="tab-panel" role="tabpanel" aria-labelledby="tab-layers" hidden>
            <div class="layer-actions">
              <button type="button" id="z-front" class="btn">{labels.front}</button>
              <button type="button" id="z-forward" class="btn">{labels.forward}</button>
              <button type="button" id="z-backward" class="btn">{labels.backward}</button>
              <button type="button" id="z-back" class="btn">{labels.back}</button>
            </div>
            <div id="layers-list" class="layers-list"></div>
          </section>

          <section id="panel-assets" class="tab-panel" role="tabpanel" aria-labelledby="tab-assets" hidden>
            <div class="asset-tools">
              <input id="asset-search" class="control" type="text" placeholder="Search assets..." />
              <div id="asset-category-tabs" class="asset-category-tabs" role="tablist" aria-label="Asset categories">
                <button type="button" class="asset-category-tab is-active" data-asset-category="Icons" role="tab" aria-selected="true">Icons</button>
                <button type="button" class="asset-category-tab" data-asset-category="Dividers" role="tab" aria-selected="false">Dividers</button>
                <button type="button" class="asset-category-tab" data-asset-category="Badges" role="tab" aria-selected="false">Badges</button>
                <button type="button" class="asset-category-tab" data-asset-category="Stickers" role="tab" aria-selected="false">Stickers</button>
              </div>
            </div>
            <div id="assets-list" class="assets-list"></div>
            <div class="asset-pagination">
              <button type="button" id="asset-load-more" class="btn">Load more</button>
              <span id="asset-page-label">Page 1</span>
            </div>
          </section>

          <section id="panel-theme" class="tab-panel" role="tabpanel" aria-labelledby="tab-theme" hidden>
            <div class="theme-panel">
              <div class="theme-subtabs" role="tablist" aria-label="Theme subtabs">
                <button type="button" class="theme-subtab is-active" data-theme-subtab="page" role="tab" aria-selected="true">Page</button>
              </div>

              <section class="theme-subpanel active" data-theme-panel="page" role="tabpanel">
                <h3>Page background</h3>
                <label class="field"><span>Background color</span><input id="theme-page-color" class="control" type="color" /></label>

                <div class="theme-brand-colors">
                  <h3>{labels.brandColors}</h3>
                  <div id="brand-swatches" class="brand-swatches" role="group" aria-label={labels.brandColors}></div>
                </div>
                <div class="theme-brand-colors">
                  <h3>{labels.recentColors}</h3>
                  <div id="recent-swatches" class="brand-swatches recent-swatches" role="group" aria-label={labels.recentColors}></div>
                </div>

                <details class="theme-advanced">
                  <summary>Advanced</summary>
                  <h3>New elements defaults</h3>
                  <label class="field"><span>New text color</span><input id="theme-default-text" class="control" type="color" /></label>
                  <label class="field"><span>New shape fill</span><input id="theme-default-fill" class="control" type="color" /></label>
                  <label class="field"><span>New stroke color</span><input id="theme-default-stroke" class="control" type="color" /></label>
                  <label class="field"><span>New corner radius</span><input id="theme-default-radius" class="control" type="number" min="0" max="80" step="1" /></label>
                  <div id="style-presets" class="theme-preset-list"></div>
                  <div class="theme-actions">
                    <button type="button" id="preset-apply-selection" class="btn">Apply to selection</button>
                    <button type="button" id="preset-apply-all" class="btn">Apply to all nodes</button>
                  </div>
                </details>
              </section>

              <details class="theme-advanced">
                <summary>Workspace (Advanced, editor only)</summary>
                <p class="theme-note">Does not affect PDF export.</p>
                <label class="field"><span>Solid color</span><input id="theme-workspace-color" class="control" type="color" /></label>
                <div class="field"><span>Gradient presets</span>
                  <div id="theme-gradients" class="theme-preset-list"></div>
                </div>
                <label class="checkline"><input id="theme-workspace-pattern" type="checkbox" />Subtle dots/grid background</label>
              </details>
            </div>
          </section>
        </div>
      </aside>

      <section class="panel canvas-panel">
        <div id="arrange-toolbar" class="arrange-toolbar" hidden>
          <span>{labels.arrange}</span>
          <button type="button" data-arrange="align-left" class="btn">⟸</button>
          <button type="button" data-arrange="align-center" class="btn">↔</button>
          <button type="button" data-arrange="align-right" class="btn">⟹</button>
          <button type="button" data-arrange="align-top" class="btn">⟰</button>
          <button type="button" data-arrange="align-middle" class="btn">↕</button>
          <button type="button" data-arrange="align-bottom" class="btn">⟱</button>
          <button type="button" data-arrange="dist-h" class="btn">⇆</button>
          <button type="button" data-arrange="dist-v" class="btn">⇅</button>
          <span class="arrange-sep" aria-hidden="true">|</span>
          <button type="button" id="copy-style-btn" class="btn" title={labels.copyStyle}>{labels.copyStyle}</button>
          <button type="button" id="paste-style-btn" class="btn" title={labels.pasteStyle}>{labels.pasteStyle}</button>
        </div>
        <div id="canvas-scroll-wrapper" class="canvas-scroll-wrapper" tabindex="-1">
          <div id="workspace" class="workspace">
          <div id="canvas-inner" class="canvas-inner">
          <div id="ruler-corner" class="ruler-corner" aria-hidden="true"></div>
          <div id="ruler-top" class="ruler ruler-h" aria-hidden="true"></div>
          <div id="ruler-left" class="ruler ruler-v" aria-hidden="true"></div>
          <div id="page" class="page">
            <div id="safe-area-overlay" class="safe-area-overlay" aria-hidden="true" hidden></div>
            <div id="drop-preview" class="drop-preview" aria-hidden="true"></div>
            <div id="guide-x" class="guide guide-x"></div>
            <div id="guide-y" class="guide guide-y"></div>
            <div id="multi-box" class="multi-box" hidden></div>
            <div id="marquee" class="marquee" hidden></div>
            <div id="stage" class="stage" tabindex="0" aria-label="Canvas"></div>
          </div>
          </div>
        </div>
        </div>
      </section>

      <aside class="panel right-panel">
        <h2 id="inspector-title">{labels.noSelection}</h2>
        <div id="inspector-scroll" class="right-scroll">
          <div id="inspector-empty" class="ins-note">{labels.selectObject}</div>
          <div id="inspector-content" hidden>
            <section class="ins-group" data-for="common">
              <div class="inspector-grid">
                <label class="field"><span>X (mm)</span><input id="ins-x" class="control" type="number" step="0.5" /></label>
                <label class="field"><span>Y (mm)</span><input id="ins-y" class="control" type="number" step="0.5" /></label>
                <label class="field"><span>W (mm)</span><input id="ins-w" class="control" type="number" step="0.5" /></label>
                <label class="field"><span>H (mm)</span><input id="ins-h" class="control" type="number" step="0.5" /></label>
                <label class="field"><span>Opacity</span><input id="ins-opacity" class="control" type="range" min="0.1" max="1" step="0.05" /></label>
                <label class="field toggle-field"><span>{labels.shadow}</span><input id="ins-shadow" type="checkbox" /></label>
              </div>
            </section>

            <section class="ins-group" data-for="text">
              <div class="inspector-grid">
                <label class="field"><span>Font</span><select id="ins-font-family" class="control"><option value="Inter,system-ui">Inter</option><option value="Arial,sans-serif">Arial</option><option value="Georgia,serif">Georgia</option><option value="Verdana,sans-serif">Verdana</option><option value="Trebuchet MS,sans-serif">Trebuchet MS</option><option value="Segoe UI,sans-serif">Segoe UI</option></select></label>
                <label class="field"><span>Font size</span><input id="ins-font-size" class="control" type="number" min="8" max="72" /></label>
                <label class="field"><span>Weight</span><select id="ins-font-weight" class="control"><option value="400">Regular</option><option value="600">Semi-bold</option><option value="700">Bold</option></select></label>
                <label class="field toggle-field"><span>Italic</span><input id="ins-italic" type="checkbox" /></label>
                <label class="field"><span>Align</span><select id="ins-align" class="control"><option value="left">Left</option><option value="center">Center</option><option value="right">Right</option></select></label>
                <label class="field"><span>Text color</span><input id="ins-text-color" class="control" type="color" /></label>
                <label class="field"><span>Line height</span><input id="ins-line-height" class="control" type="number" min="1" max="2.4" step="0.05" /></label>
              </div>
            </section>

            <section class="ins-group" data-for="shape">
              <div class="inspector-grid">
                <label class="field"><span>Fill</span><input id="ins-fill" class="control" type="color" /></label>
                <label class="field"><span>Stroke</span><input id="ins-stroke" class="control" type="color" /></label>
                <label class="field"><span>Stroke w</span><input id="ins-stroke-width" class="control" type="number" min="0.5" max="20" step="0.5" /></label>
                <label class="field"><span>Radius</span><input id="ins-radius" class="control" type="number" min="0" max="80" /></label>
              </div>
            </section>

            <section class="ins-group" data-for="line">
              <div class="inspector-grid">
                <label class="field"><span>Line w</span><input id="ins-thickness" class="control" type="number" min="1" max="20" /></label>
                <label class="field"><span>Line color</span><input id="ins-color" class="control" type="color" /></label>
              </div>
            </section>

            <section class="ins-group" data-for="image">
              <div class="inspector-grid">
                <label class="field"><span>Image fit</span><select id="ins-object-fit" class="control"><option value="contain">Contain</option><option value="cover">Cover</option></select></label>
              </div>
            </section>

            <section class="ins-group" data-for="svg">
              <div class="inspector-grid">
                <label class="field"><span>Fill</span><input id="ins-svg-fill" class="control" type="color" /></label>
                <label class="field"><span>Stroke</span><input id="ins-svg-stroke" class="control" type="color" /></label>
                <label class="field"><span>Rotation</span><input id="ins-rotation" class="control" type="range" min="0" max="360" step="1" /></label>
              </div>
            </section>

            <section class="ins-group" data-for="list">
              <div class="inspector-grid">
                <label class="field"><span>Line height</span><input id="ins-list-line-height" class="control" type="number" min="1" max="2.4" step="0.05" /></label>
                <label class="field"><span>List style</span><select id="ins-list-style" class="control"><option value="checkbox">Checkbox</option><option value="bullet">Bullet</option></select></label>
              </div>
            </section>

            <section class="ins-group" data-for="table">
              <div class="table-controls">
                <strong>Table structure</strong>
                <div class="table-controls-grid">
                  <label class="field"><span>Rows</span><input id="ins-table-rows" class="control" type="number" min="2" max="10" step="1" /></label>
                  <label class="field"><span>Cols</span><input id="ins-table-cols" class="control" type="number" min="2" max="10" step="1" /></label>
                </div>
              </div>
            </section>
          </div>
          <p id="ins-note" class="ins-note"></p>
        </div>
      </aside>
    </main>

    <footer class="pages-strip">
      <div class="pages-actions">
        <button type="button" id="add-page" class="btn">{labels.addPage}</button>
        <button type="button" id="dup-page" class="btn">{labels.dupPage}</button>
        <button type="button" id="del-page" class="btn">{labels.delPage}</button>
      </div>
      <div id="pages-list" class="pages-list"></div>
    </footer>
    <div id="toast" class="toast" role="status" aria-live="polite"></div>
    <div id="context-menu" class="context-menu" hidden>
      <button type="button" data-context-action="duplicate">{labels.contextDuplicate}</button>
      <button type="button" data-context-action="delete">{labels.contextDelete}</button>
      <button type="button" data-context-action="front">{labels.contextFront}</button>
      <button type="button" data-context-action="back">{labels.contextBack}</button>
      <button type="button" data-context-action="lock">{labels.contextLock}</button>
      <button type="button" data-context-action="visibility">{labels.contextVisibility}</button>
      <button type="button" data-context-action="copy">{labels.contextCopy}</button>
      <button type="button" data-context-action="paste">{labels.contextPaste}</button>
    </div>

    <div id="template-modal" class="template-modal" hidden>
      <div class="template-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="template-modal-title">
        <div class="template-modal-header">
          <h2 id="template-modal-title">{labels.templateTitle}</h2>
          <button type="button" id="template-close-btn" class="btn">{labels.close}</button>
        </div>
        <div class="template-modal-controls">
          <input id="template-search" type="text" class="control" placeholder={labels.searchTemplates} />
          <select id="template-category" class="control">
            <option value="all">All categories</option>
          </select>
        </div>
        <div class="template-section">
          <h3>{labels.blankProject}</h3>
          <button type="button" id="template-blank-btn" class="template-card blank">
            <div class="template-thumb placeholder">Blank</div>
            <div class="template-card-body">
              <strong>{labels.blankProject}</strong>
              <span>Start from scratch</span>
            </div>
          </button>
        </div>
        <div class="template-section">
          <h3>Templates</h3>
          <div id="template-list" class="template-grid"></div>
        </div>
        <div class="template-section">
          <h3>Packs</h3>
          <div id="pack-list" class="template-grid"></div>
        </div>
        <label class="checkline template-checkline">
          <input type="checkbox" id="template-hide-toggle" />
          Don’t show again
        </label>
      </div>
    </div>

    <div id="shortcuts-overlay" class="shortcuts-overlay" hidden>
      <div class="shortcuts-dialog" role="dialog" aria-labelledby="shortcuts-title">
        <div class="shortcuts-header">
          <h2 id="shortcuts-title">{labels.shortcutsTitle}</h2>
          <button type="button" id="shortcuts-close" class="btn">×</button>
        </div>
        <ul class="shortcuts-list">
          <li><kbd>Ctrl</kbd><kbd>Z</kbd> {labels.shortcutsUndo}</li>
          <li><kbd>Ctrl</kbd><kbd>Shift</kbd><kbd>Z</kbd> {labels.shortcutsRedo}</li>
          <li><kbd>Ctrl</kbd><kbd>D</kbd> {labels.shortcutsDuplicate}</li>
          <li><kbd>Delete</kbd> / <kbd>Backspace</kbd> {labels.shortcutsDelete}</li>
          <li><kbd>Ctrl</kbd><kbd>G</kbd> {labels.shortcutsGroup}</li>
          <li><kbd>Ctrl</kbd><kbd>Shift</kbd><kbd>G</kbd> {labels.shortcutsUngroup}</li>
          <li><kbd>Space</kbd> + drag {labels.shortcutsPan}</li>
          <li><kbd>Escape</kbd> {labels.shortcutsDeselect}</li>
        </ul>
      </div>
    </div>

    <div id="tips-overlay" class="shortcuts-overlay" hidden>
      <div class="shortcuts-dialog" role="dialog" aria-labelledby="tips-title">
        <div class="shortcuts-header">
          <h2 id="tips-title">{labels.tipsTitle}</h2>
          <button type="button" id="tips-close" class="btn">×</button>
        </div>
        <ul class="shortcuts-list tips-list">
          <li>{labels.tipsDrag}</li>
          <li>{labels.tipsEdit}</li>
          <li>{labels.tipsArrange}</li>
          <li>{labels.tipsShortcuts}</li>
        </ul>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ labels }}>
    window.__PRINTFORGE_LABELS = typeof labels !== "undefined" ? labels : {};
  </script>
  <script>
    import { createDocFromTemplate, listTemplates } from "../../../app/templates/index";
    import { validateTemplates } from "../../../app/templates/validate";
    import { ASSETS } from "../../../app/assets";
    import { exportDocToPDF } from "../../../app/pdfExport";
    import { exportPageToPng } from "../../../app/pageToPng";
    const labels = window.__PRINTFORGE_LABELS || {};
    const mmToPx = (mm) => mm * 3.7795275591;
    const pxToMm = (px) => px / 3.7795275591;
    const clamp = (v, min, max) => Math.min(max, Math.max(min, v));
    const createId = (prefix = 'id') => `${prefix}_${Math.random().toString(36).slice(2, 10)}`;
    const pageDimensionsMm = (size, orientation) => {
      const base = size === 'A4' ? { wMm: 210, hMm: 297 } : { wMm: 148, hMm: 210 };
      return orientation === 'portrait' ? base : { wMm: base.hMm, hMm: base.wMm };
    };
    const snapMm = (v, step, enabled) => enabled ? Math.round(v / step) * step : v;

    const DOC_STORAGE_KEY = 'printforge_doc_v2d';
    const ASSETS_PAGE_SIZE = 24;
    const RECENT_PROJECTS_KEY = 'printforge_recent_projects_v1';
    const loadFromLocal = () => { try { const raw = localStorage.getItem(DOC_STORAGE_KEY); return raw ? JSON.parse(raw) : null; } catch { return null; } };
