        el.rulerLeft.style.gridColumn = '1';
        el.rulerLeft.style.gridRow = '2';
        el.page.style.gridColumn = '2';
        el.page.style.gridRow = '2';
        el.rulerTop.style.width = `${pw}px`;
        el.rulerTop.style.height = '22px';
        el.rulerLeft.style.width = '22px';
        el.rulerLeft.style.height = `${ph}px`;
        const step = 10;
        let ticksH = '';
        for (let i = 0; i <= d.wMm; i += step) ticksH += `<span class="ruler-tick" style="left:${mmToPx(i)}px">${i}</span>`;
        let ticksV = '';
        for (let i = 0; i <= d.hMm; i += step) ticksV += `<span class="ruler-tick" style="top:${mmToPx(i)}px">${i}</span>`;
        el.rulerTop.innerHTML = ticksH;
        el.rulerLeft.innerHTML = ticksV;
      } else {
        el.canvasInner.style.display = 'block';
        el.canvasInner.style.transform = '';
        el.canvasInner.style.width = '';
        el.canvasInner.style.height = '';
        el.canvasInner.style.gridTemplateColumns = '';
        el.canvasInner.style.gridTemplateRows = '';
        el.page.style.transform = `scale(${doc.zoom})`;
        el.page.style.gridColumn = '';
        el.page.style.gridRow = '';
      }
      el.page.classList.toggle('grid', doc.grid.enabled);
      el.page.style.setProperty('--grid-step-px', `${mmToPx(doc.grid.stepMm)}px`);
      el.page.style.setProperty('--grid-major-px', `${mmToPx(doc.grid.stepMm * 5)}px`);
      el.stage.style.width = `${mmToPx(d.wMm)}px`;
      el.stage.style.height = `${mmToPx(d.hMm)}px`;
    }

    function renderThemePanel() {
      el.themeWorkspaceColor.value = doc.workspaceBg || '#e5e7eb';
      el.themeWorkspacePattern.checked = !!doc.workspacePatternOn;
      el.themeGradients.innerHTML = WORKSPACE_GRADIENTS.map((item) => `<button type="button" class="btn ${doc.workspaceGradientId === item.id ? 'is-active' : ''}" data-gradient-id="${item.id}">${item.name}</button>`).join('');
      el.themeGradients.querySelectorAll('[data-gradient-id]').forEach((btn) => {
        btn.onclick = () => { doc.workspaceGradientId = btn.dataset.gradientId; commitChange(); render(); };
      });

      el.themePageColor.value = doc.pageBg || '#ffffff';
      el.themeDefaultText.value = doc.defaults.textColor || '#111827';
      el.themeDefaultFill.value = doc.defaults.fillColor || '#e2e8f0';
      el.themeDefaultStroke.value = doc.defaults.strokeColor || '#94a3b8';
      el.themeDefaultRadius.value = String(doc.defaults.radius ?? 6);

      el.stylePresets.innerHTML = Object.values(STYLE_PRESETS).map((item) => `<button type="button" class="btn" data-style-preset="${item.id}">${item.name}</button>`).join('');
      el.stylePresets.querySelectorAll('[data-style-preset]').forEach((btn) => {
        btn.onclick = () => {
          doc.pendingStylePreset = btn.dataset.stylePreset;
          el.stylePresets.querySelectorAll('[data-style-preset]').forEach((item) => item.classList.toggle('is-active', item === btn));
        };
      });
      if (!doc.pendingStylePreset) {
        doc.pendingStylePreset = 'minimal';
        const first = el.stylePresets.querySelector('[data-style-preset]');
        if (first) first.classList.add('is-active');
      }

      const swatches = doc.brandSwatches || [];
      el.brandSwatchesContainer.innerHTML = swatches.map((hex, idx) => `<button type="button" class="brand-swatch" data-brand-color="${hex}" title="${hex}" style="background:${hex}" aria-label="Apply ${hex}"></button>`).join('');
      el.brandSwatchesContainer.querySelectorAll('.brand-swatch').forEach((btn) => {
        btn.onclick = () => {
          const color = btn.dataset.brandColor;
          if (!color || !selectedNodeIds.size) return;
          addRecentColor(color);
          selectedNodes().forEach((n) => {
            if (n.locked) return;
            if (['text', 'heading', 'paragraph', 'datelabel'].includes(n.type)) n.props.color = color;
            else if (['box', 'highlight', 'roundedrect', 'circle', 'svg'].includes(n.type)) n.props.fill = color;
            else if (['line', 'divider'].includes(n.type)) n.props.color = color;
          });
          commitChange();
          render();
        };
      });

      const recent = doc.recentColors || [];
      el.recentSwatchesContainer.innerHTML = recent.length ? recent.map((hex) => `<button type="button" class="brand-swatch" data-recent-color="${hex}" title="${hex}" style="background:${hex}" aria-label="Apply ${hex}"></button>`).join('') : '';
      el.recentSwatchesContainer.querySelectorAll('[data-recent-color]').forEach((btn) => {
        btn.onclick = () => {
          const color = btn.dataset.recentColor;
          if (!color) return;
          addRecentColor(color);
          if (!selectedNodeIds.size) return;
          selectedNodes().forEach((n) => {
            if (n.locked) return;
            if (['text', 'heading', 'paragraph', 'datelabel'].includes(n.type)) n.props.color = color;
            else if (['box', 'highlight', 'roundedrect', 'circle', 'svg'].includes(n.type)) n.props.fill = color;
            else if (['line', 'divider'].includes(n.type)) n.props.color = color;
          });
          commitChange();
          render();
        };
      });
    }

    function renderPages() {
      el.pagesList.innerHTML = '';
      doc.pages.forEach((page, i) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = `page-thumb ${page.id === doc.activePageId ? 'active' : ''}`;
        chip.textContent = page.name || `Page ${i + 1}`;
        chip.draggable = true;
        chip.dataset.pageId = page.id;
        chip.onclick = (e) => { if (!e.defaultPrevented) { setPrimarySelection(null); doc.activePageId = page.id; render(); } };
        chip.ondragstart = (e) => { e.dataTransfer.setData('text/plain', page.id); e.dataTransfer.effectAllowed = 'move'; chip.classList.add('page-thumb-dragging'); };
        chip.ondragend = () => chip.classList.remove('page-thumb-dragging');
        chip.ondragover = (e) => { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; chip.classList.add('page-thumb-drop-target'); };
        chip.ondragleave = () => chip.classList.remove('page-thumb-drop-target');
        chip.ondrop = (e) => {
          e.preventDefault();
          chip.classList.remove('page-thumb-drop-target');
          const srcId = e.dataTransfer.getData('text/plain');
          if (!srcId || srcId === page.id) return;
          const srcIdx = doc.pages.findIndex((p) => p.id === srcId);
          const tgtIdx = doc.pages.findIndex((p) => p.id === page.id);
          if (srcIdx === -1 || tgtIdx === -1) return;
          const [moved] = doc.pages.splice(srcIdx, 1);
          doc.pages.splice(tgtIdx, 0, moved);
          commitChange();
          render();
        };
        el.pagesList.appendChild(chip);
      });
      el.delPage.disabled = doc.pages.length <= 1;
    }

    function renderLayers() {
      const p = activePage();
      el.layersList.innerHTML = '';
      if (!p) return;
      const sorted = [...p.nodes].sort((a,b)=>b.z-a.z);
      sorted.forEach((n, idx) => {
        const row = document.createElement('div');
        row.className = `layer-row ${selectedNodeIds.has(n.id) ? 'active' : ''}`;
        row.draggable = true;
        row.dataset.id = n.id;
        row.innerHTML = `<span class="layer-icon">${n.type[0].toUpperCase()}</span><span class="layer-name">${n.name || `${n.type} ${idx+1}`}</span><button type="button" class="icon-btn layer-eye" title="Toggle visibility">${n.visible ? '👁' : '🚫'}</button><button type="button" class="icon-btn layer-lock" title="Toggle lock">${n.locked ? '🔒' : '🔓'}</button><button type="button" class="icon-btn layer-trash" title="Delete layer">🗑</button>`;
        row.onclick = (e) => {
          if (e.target.classList.contains('layer-eye')) { n.visible = !n.visible; commitChange(); render(); return; }
          if (e.target.classList.contains('layer-lock')) { n.locked = !n.locked; commitChange(); render(); return; }
          if (e.target.classList.contains('layer-trash')) { deleteNodeById(n.id, true); return; }
          if (e.shiftKey) toggleNodeSelection(n.id); else setSelection([n.id], n.id); render();
        };
        row.ondragstart = () => { draggingLayerId = n.id; };
        row.ondragover = (e) => e.preventDefault();
        row.ondrop = (e) => {
          e.preventDefault();
          if (!draggingLayerId || draggingLayerId === n.id) return;
          const list = [...p.nodes].sort((a,b)=>b.z-a.z);
          const from = list.findIndex((x)=>x.id===draggingLayerId);
          const to = list.findIndex((x)=>x.id===n.id);
          const [item] = list.splice(from,1); list.splice(to,0,item);
          list.forEach((node, i) => node.z = list.length - i);
          commitChange();
          render();
        };
        el.layersList.appendChild(row);
      });
    }

    function listRowsHtml(n) {
      const items = (n.props.items && n.props.items.length ? n.props.items : ['Item 1']).map((item, idx) => {
        const marker = n.props.listStyle === 'checkbox' ? '☐' : '•';
        return `<div class="list-row"><span class="list-marker">${marker}</span><span class="list-item" contenteditable="true" data-list-item="${idx}">${item}</span></div>`;
      }).join('');
      return `<div class="meta-content list-content" style="line-height:${n.props.lineHeight||1.4};opacity:${n.props.opacity||1}">${items}<button type="button" class="list-add" data-add-item="true">+ item</button></div>`;
    }

    function nodeHtml(n) {
      if (["text","heading","paragraph","datelabel"].includes(n.type)) {
        const style = `font-size:${n.props.fontSize||14}px;font-family:${n.props.fontFamily||doc.defaults.fontFamily||'Inter,system-ui'};font-weight:${n.props.fontWeight||400};font-style:${n.props.italic?'italic':'normal'};text-align:${n.props.align||'left'};line-height:${n.props.lineHeight||1.3};opacity:${n.props.opacity||1};color:${n.props.color||doc.defaults.textColor||'#111827'};`;
        return `<div class="text-content" style="${style}" contenteditable="true">${n.props.text || ''}</div>`;
      }
      if (["box","highlight","roundedrect","circle"].includes(n.type)) {
        const radius = n.type === 'circle' ? '9999px' : `${n.props.radius || 0}px`;
        return `<div class="box-content" style="background:${n.props.fill||doc.defaults.fillColor||'#e2e8f0'};border:${n.props.strokeWidth||1}px solid ${n.props.stroke||doc.defaults.strokeColor||'#94a3b8'};border-radius:${radius};opacity:${n.props.opacity||1};"></div>`;
      }
      if (["line","divider"].includes(n.type)) return `<div class="line-content" style="height:${n.props.thickness||2}px;background:${n.props.color||'#334155'};opacity:${n.props.opacity||1}"></div>`;
      if (n.type === 'checkbox') return `<div class="meta-content">${n.props.checked?'☑':'☐'} ${n.props.text||'Checkbox item'}</div>`;
      if (n.type === 'checklist' || n.type === 'bulletlist') return listRowsHtml(n);
      if (n.type === 'table') {
        const rows=n.props.rows||3, cols=n.props.cols||3;
        return `<div class="table-content" style="grid-template-columns:repeat(${cols},1fr);opacity:${n.props.opacity||1}">${Array.from({length:rows*cols},()=>'<div></div>').join('')}</div>`;
      }
      if (n.type === 'calendar') {
        const month = new Date(n.props.year||2026,(n.props.month||1)-1,1).toLocaleString('en',{month:'long',year:'numeric'});
        return `<div class="calendar-content" style="opacity:${n.props.opacity||1}"><div class="cal-title">${month}</div><div class="cal-grid">${Array.from({length:42},(_,i)=>`<span>${i<31?i+1:''}</span>`).join('')}</div></div>`;
      }
      if (n.type === 'image') return `<img class="image-content" style="object-fit:${n.props.objectFit||'contain'};opacity:${n.props.opacity||1}" src="${n.props.src||''}" alt="image"/>`;
      if (n.type === 'svg') return `<div class="svg-content" style="opacity:${n.props.opacity ?? 1};transform:rotate(${n.props.rotation || 0}deg);--svg-fill:${n.props.fill || doc.defaults.fillColor || '#1d4ed8'};--svg-stroke:${n.props.stroke || doc.defaults.strokeColor || '#334155'};">${n.props.svgMarkup || ''}</div>`;
      return '';
    }

    function attachListHandlers(nodeEl, n) {
      const items = [...nodeEl.querySelectorAll('[data-list-item]')];
      const syncFromDom = () => {
        n.props.items = items.map((item) => item.textContent ?? '');
      };
      const focusItem = (itemIdx) => {
        requestAnimationFrame(() => {
          const target = el.stage.querySelector(`[data-id="${n.id}"] [data-list-item="${itemIdx}"]`);
          target?.focus();
        });
      };
      items.forEach((item, idx) => {
        item.onfocus = () => {
          if (selectedNodeId !== n.id) {
            setSelection([n.id], n.id);
            render();
            focusItem(idx);
            return;
          }
        };
        item.oninput = () => {
          syncFromDom();
          markDirtyNow();
          scheduleListCommit(n.id, idx);
        };
        item.onkeydown = (ev) => {
          if (ev.key === 'Enter') {
            ev.preventDefault();
            ev.stopPropagation();
            syncFromDom();
            const next = [...(n.props.items || [])];
            next.splice(idx + 1, 0, '');
            n.props.items = next;
            commitChange();
            renderNodes();
            focusItem(idx + 1);
          }
          if (ev.key === 'Backspace' && item.textContent.trim() === '' && (n.props.items || []).length > 1) {
            ev.preventDefault();
            ev.stopPropagation();
            syncFromDom();
            const next = [...(n.props.items || [])];
            next.splice(idx, 1);
            n.props.items = next;
            commitChange();
            renderNodes();
            focusItem(Math.max(0, idx - 1));
          }
        };
        item.onblur = () => {
          clearListCommitTimer(n.id, idx);
          syncFromDom();
          commitChange();
        };
      });
      const addBtn = nodeEl.querySelector('[data-add-item]');
      if (addBtn) {
        addBtn.onpointerdown = (ev) => {
          ev.stopPropagation();
        };
        addBtn.onclick = (ev) => {
          ev.preventDefault();
          ev.stopPropagation();
          n.props.items = [...(n.props.items || []), ''];
          commitChange();
          renderNodes();
          focusItem((n.props.items || []).length - 1);
        };
      }
    }

    function renderNodes() {
      const p = activePage();
      el.stage.innerHTML = '';
      if (!p) return;
      [...p.nodes].sort((a,b)=>a.z-b.z).forEach((n) => {
        if (!n.visible) return;
        const d = document.createElement('div');
        d.className = `node node-${n.type} ${selectedNodeIds.has(n.id) ? 'selected' : ''}`;
        d.dataset.id = n.id;
        d.style.left = `${mmToPx(n.xMm)}px`;
        d.style.top = `${mmToPx(n.yMm)}px`;
        d.style.width = `${mmToPx(n.wMm)}px`;
        d.style.height = `${mmToPx(n.hMm)}px`;
        d.style.zIndex = String(n.z);
        if (n.props.boxShadow) d.style.boxShadow = n.props.boxShadow;
        d.innerHTML = nodeHtml(n);

        const editable = d.querySelector('.text-content[contenteditable="true"]');
        if (editable) {
          editable.oninput = () => { n.props.text = editable.innerText; dirty = true; setSaveIndicator(); autosaveSchedule(); };
          editable.onblur = () => commitChange();
        }
        if (n.type === 'checklist' || n.type === 'bulletlist') attachListHandlers(d, n);
        d.oncontextmenu = (event) => {
          event.preventDefault();
          setSelection([n.id], n.id);
          openContextMenu(event.clientX, event.clientY, n.id);
          render();
        };

        if (n.id === selectedNodeId && selectedNodeIds.size <= 1 && !n.locked) {
          ["nw","ne","sw","se"].forEach((h) => {
            const hEl = document.createElement('button');
            hEl.type='button'; hEl.className=`handle ${h}`; hEl.dataset.handle=h;
            d.appendChild(hEl);
          });
        }

        el.stage.appendChild(d);
      });
      syncInspector();
    }

    function enableControl(ctrl, enabled, value, isCheckbox=false) {
      ctrl.disabled = !enabled;
      if (value !== undefined) {
        if (isCheckbox) ctrl.checked = !!value;
        else ctrl.value = String(value);
      }
    }

    function syncInspector() {
      const n = activeNode();
      const selectedCount = selectedNodeIds.size;
      const has = !!n && selectedCount <= 1;
      const isMulti = selectedCount > 1;
      el.inspectorTitle.textContent = selectedCount > 1 ? `Selected: ${selectedCount} items` : (has ? `Selected: ${n.type === 'table' ? 'table (rows/cols)' : n.type}` : 'No selection');
      el.delBtn.disabled = selectedCount === 0;

      const groupForType = {
        text: 'text', heading: 'text', paragraph: 'text', datelabel: 'text',
        checklist: 'list', bulletlist: 'list',
        box: 'shape', highlight: 'shape', roundedrect: 'shape', circle: 'shape',
        line: 'line', divider: 'line',
        image: 'image', svg: 'svg', table: 'table',
      };
      const activeGroup = has ? (groupForType[n.type] || null) : null;
      el.inspectorGroups.forEach((group) => {
        const target = group.dataset.for;
        const show = isMulti ? target === 'common' : (has ? (target === 'common' || target === activeGroup) : false);
        group.style.display = show ? 'block' : 'none';
      });
      el.inspectorContent.hidden = !has && !isMulti;
      el.inspectorEmpty.hidden = has || isMulti;
      el.note.hidden = !isMulti;
      el.note.textContent = isMulti ? 'Use Arrange actions for multi-select.' : '';
      if (!has && !isMulti) return;

      enableControl(el.insX, has, n?.xMm?.toFixed?.(1));
      enableControl(el.insY, has, n?.yMm?.toFixed?.(1));
      enableControl(el.insW, has, n?.wMm?.toFixed?.(1));
      enableControl(el.insH, has, n?.hMm?.toFixed?.(1));

      const isText = n && ["text","heading","paragraph","datelabel"].includes(n.type);
      enableControl(el.insFontFamily, isText, n?.props.fontFamily || 'Inter,system-ui');
      enableControl(el.insFontSize, isText, n?.props.fontSize || 14);
      enableControl(el.insFontWeight, isText, n?.props.fontWeight || 400);
      enableControl(el.insItalic, isText, n?.props.italic || false, true);
      enableControl(el.insAlign, isText, n?.props.align || 'left');
      enableControl(el.insTextColor, isText, n?.props.color || doc.defaults.textColor || '#111827');

      const isShape = n && ["box","highlight","roundedrect","circle"].includes(n.type);
      const isSvg = n && n.type === 'svg';
      enableControl(el.insFill, isShape, n?.props.fill || doc.defaults.fillColor || '#e2e8f0');
      enableControl(el.insStroke, isShape, n?.props.stroke || doc.defaults.strokeColor || '#94a3b8');
      enableControl(el.insSvgFill, isSvg, n?.props.fill || doc.defaults.fillColor || '#e2e8f0');
      enableControl(el.insSvgStroke, isSvg, n?.props.stroke || doc.defaults.strokeColor || '#94a3b8');
      enableControl(el.insStrokeWidth, isShape, n?.props.strokeWidth || 1);
      enableControl(el.insRadius, isShape && n.type !== 'circle', n?.props.radius || 0);

      const isLine = n && ["line","divider"].includes(n.type);
      enableControl(el.insThickness, isLine, n?.props.thickness || 2);
      enableControl(el.insColor, isLine, n?.props.color || doc.defaults.strokeColor || '#334155');

      const isImage = n && n.type === 'image';
      const isList = n && ["checklist","bulletlist"].includes(n.type);
      enableControl(el.insObjectFit, isImage, n?.props.objectFit || 'contain');
      enableControl(el.insOpacity, has && (isSvg || isShape || isLine || isImage || isList || n?.type === 'table' || n?.type === 'calendar' || isText), n?.props.opacity ?? 1);
      enableControl(el.insShadow, has, !!n?.props.boxShadow, true);
      enableControl(el.insRotation, has && isSvg, n?.props.rotation ?? 0);

      enableControl(el.insLineHeight, isText, n?.props.lineHeight || 1.4);
      enableControl(el.insListLineHeight, isList, n?.props.lineHeight || 1.4);
      enableControl(el.insListStyle, isList, n?.props.listStyle || (n?.type === 'checklist' ? 'checkbox' : 'bullet'));
      const isTable = n && n.type === 'table';
      enableControl(el.insTableRows, isTable, clamp(Number(n?.props.rows || 4), 2, 10));
      enableControl(el.insTableCols, isTable, clamp(Number(n?.props.cols || 4), 2, 10));

      el.note.textContent = '';
    }

    function renderSelectionOverlays() {
      const box = selectionBounds();
      if (box && selectedNodeIds.size > 1) {
        el.multiBox.hidden = false;
        el.multiBox.style.left = `${mmToPx(box.left)}px`;
        el.multiBox.style.top = `${mmToPx(box.top)}px`;
        el.multiBox.style.width = `${mmToPx(box.width)}px`;
        el.multiBox.style.height = `${mmToPx(box.height)}px`;
      } else {
        el.multiBox.hidden = true;
      }
      el.arrangeToolbar.hidden = selectedNodeIds.size < 1;
      el.arrangeToolbar.querySelectorAll('[data-arrange]').forEach((btn) => { btn.disabled = selectedNodeIds.size < 2; });
      el.copyStyleBtn.disabled = selectedNodeIds.size !== 1;
      el.pasteStyleBtn.disabled = !selectedNodeIds.size || !copiedStyle || Object.keys(copiedStyle).length === 0;
    }

    function selectionIntersects(rect, node) {
      const b = nodeBounds(node);
      return !(b.left > rect.right || b.right < rect.left || b.top > rect.bottom || b.bottom < rect.top);
    }

    function applyArrange(action) {
      const nodes = selectedNodes().filter((n) => !n.locked);
      if (nodes.length < 2) return;
      const bounds = selectionBounds(nodes);
      if (!bounds) return;
      if (action === 'align-left') nodes.forEach((n) => n.xMm = bounds.left);
      if (action === 'align-center') nodes.forEach((n) => n.xMm = bounds.centerX - (n.wMm / 2));
      if (action === 'align-right') nodes.forEach((n) => n.xMm = bounds.right - n.wMm);
      if (action === 'align-top') nodes.forEach((n) => n.yMm = bounds.top);
      if (action === 'align-middle') nodes.forEach((n) => n.yMm = bounds.centerY - (n.hMm / 2));
      if (action === 'align-bottom') nodes.forEach((n) => n.yMm = bounds.bottom - n.hMm);
      if (action === 'dist-h') {
        const ordered = [...nodes].sort((a, b) => a.xMm - b.xMm);
        if (ordered.length > 2) {
          const totalW = ordered.reduce((sum, n) => sum + n.wMm, 0);
          const gap = Math.max(0, (bounds.width - totalW) / (ordered.length - 1));
          let x = bounds.left;
          ordered.forEach((n) => { n.xMm = x; x += n.wMm + gap; });
        }
      }
      if (action === 'dist-v') {
        const ordered = [...nodes].sort((a, b) => a.yMm - b.yMm);
        if (ordered.length > 2) {
          const totalH = ordered.reduce((sum, n) => sum + n.hMm, 0);
          const gap = Math.max(0, (bounds.height - totalH) / (ordered.length - 1));
          let y = bounds.top;
          ordered.forEach((n) => { n.yMm = y; y += n.hMm + gap; });
        }
      }
      commitChange();
      render();
    }

    function groupSelection() {
      const nodes = selectedNodes().filter((n) => !n.locked);
      if (nodes.length < 2) return;
      const gid = createId('group');
      nodes.forEach((n) => n.groupId = gid);
      commitChange();
      render();
    }

    function ungroupSelection() {
      const p = activePage();
      if (!p) return;
      const groupIds = [...new Set(selectedNodes().map((n) => n.groupId).filter(Boolean))];
      if (!groupIds.length) return;
      p.nodes.forEach((n) => { if (groupIds.includes(n.groupId)) n.groupId = null; });
      commitChange();
      render();
    }

    const STYLE_KEYS = ['color', 'fill', 'stroke', 'strokeWidth', 'radius', 'fontSize', 'fontFamily', 'fontWeight', 'italic', 'align', 'thickness', 'boxShadow'];
    function copyStyle() {
      const n = activeNode();
      if (!n || selectedNodeIds.size !== 1) return;
      copiedStyle = {};
      STYLE_KEYS.forEach((k) => { if (n.props[k] !== undefined) copiedStyle[k] = n.props[k]; });
    }
    function pasteStyle() {
      if (!copiedStyle || Object.keys(copiedStyle).length === 0 || !selectedNodeIds.size) return;
      const textTypes = ['text', 'heading', 'paragraph', 'datelabel'];
      const shapeTypes = ['box', 'highlight', 'roundedrect', 'circle', 'svg'];
      const lineTypes = ['line', 'divider'];
      selectedNodes().forEach((n) => {
        if (n.locked) return;
        if (copiedStyle.color !== undefined && (textTypes.includes(n.type) || lineTypes.includes(n.type))) n.props.color = copiedStyle.color;
        if (copiedStyle.fill !== undefined && shapeTypes.includes(n.type)) n.props.fill = copiedStyle.fill;
        if (copiedStyle.stroke !== undefined && shapeTypes.includes(n.type)) n.props.stroke = copiedStyle.stroke;
        if (copiedStyle.strokeWidth !== undefined && shapeTypes.includes(n.type)) n.props.strokeWidth = copiedStyle.strokeWidth;
        if (copiedStyle.radius !== undefined && shapeTypes.includes(n.type) && n.type !== 'circle') n.props.radius = copiedStyle.radius;
        if (textTypes.includes(n.type)) {
          if (copiedStyle.fontSize !== undefined) n.props.fontSize = copiedStyle.fontSize;
          if (copiedStyle.fontFamily !== undefined) n.props.fontFamily = copiedStyle.fontFamily;
          if (copiedStyle.fontWeight !== undefined) n.props.fontWeight = copiedStyle.fontWeight;
          if (copiedStyle.italic !== undefined) n.props.italic = copiedStyle.italic;
          if (copiedStyle.align !== undefined) n.props.align = copiedStyle.align;
        }
        if (copiedStyle.thickness !== undefined && lineTypes.includes(n.type)) n.props.thickness = copiedStyle.thickness;
        if (copiedStyle.boxShadow !== undefined) n.props.boxShadow = copiedStyle.boxShadow;
      });
      commitChange();
      render();
    }

    function render() {
      renderFrame();
      renderPages();
      renderLayers();
      renderNodes();
      renderSelectionOverlays();
      renderThemePanel();
      switchLeftTab(activeLeftTab);
      ensureProjectName();
      document.querySelectorAll('[data-size]').forEach((b)=>b.classList.toggle('is-active', b.dataset.size===doc.pageSize));
      document.querySelectorAll('[data-orientation]').forEach((b)=>b.classList.toggle('is-active', b.dataset.orientation===doc.orientation));
      setSaveIndicator();
    }

    function createPreset(type, xMm, yMm, extra = {}) {
      const p = activePage(); if (!p) return;
      const now = new Date();
      const base = { id:createId('node'), type, name:type, xMm, yMm, wMm:80, hMm:24, z:(p.nodes.reduce((m,n)=>Math.max(m,n.z),0)+1), visible:true, locked:false, groupId:null, props:{} };
      const presets = {
        text: { name:'Text', wMm:80, hMm:22, props:{ text:'Text', fontSize:14, fontFamily:doc.defaults.fontFamily, fontWeight:400, align:'left', color: doc.defaults.textColor } },
        heading: { name:'Heading', wMm:92, hMm:24, props:{ text:'Heading', fontSize:24, fontFamily:doc.defaults.fontFamily, fontWeight:700, align:'left', color: doc.defaults.textColor } },
        paragraph: { name:'Paragraph', wMm:100, hMm:40, props:{ text:'Paragraph text', fontSize:14, fontFamily:doc.defaults.fontFamily, fontWeight:400, align:'left', lineHeight:1.45, color: doc.defaults.textColor } },
        checkbox: { name:'Checkbox', wMm:80, hMm:16, props:{ text:'Task', checked:false } },
        checklist: { name:'Checklist', wMm:80, hMm:42, props:{ items:['Item 1','Item 2'], listStyle:'checkbox', lineHeight:1.4 } },
        bulletlist: { name:'Bullet list', wMm:80, hMm:42, props:{ items:['Point 1','Point 2'], listStyle:'bullet', lineHeight:1.4 } },
        divider: { name:'Divider', wMm:100, hMm:4, props:{ thickness:2, color:doc.defaults.strokeColor } },
        line: { name:'Line', wMm:80, hMm:4, props:{ thickness:2, color:doc.defaults.strokeColor } },
        box: { name:'Box', wMm:80, hMm:45, props:{ fill:doc.defaults.fillColor, stroke:doc.defaults.strokeColor, strokeWidth:1, radius:doc.defaults.radius } },
        highlight: { name:'Highlight', wMm:80, hMm:28, props:{ fill:doc.defaults.fillColor, stroke:doc.defaults.strokeColor, strokeWidth:1, radius:doc.defaults.radius } },
        circle: { name:'Circle', wMm:32, hMm:32, props:{ fill:doc.defaults.fillColor, stroke:doc.defaults.strokeColor, strokeWidth:1 } },
        roundedrect: { name:'Rounded rect', wMm:80, hMm:42, props:{ fill:doc.defaults.fillColor, stroke:doc.defaults.strokeColor, strokeWidth:1, radius:doc.defaults.radius } },
        datelabel: { name:'Date', wMm:78, hMm:16, props:{ text:now.toISOString().slice(0,10), fontSize:13, fontFamily:doc.defaults.fontFamily, fontWeight:600, align:'left', color: doc.defaults.textColor } },
        table: { name:'Table', wMm:92, hMm:58, props:{ rows:4, cols:4 } },
        calendar: { name:'Calendar', wMm:92, hMm:72, props:{ month:now.getMonth()+1, year:now.getFullYear() } },
        image: { name:'Image', wMm:86, hMm:62, props:{ src:'', objectFit:'contain', opacity:1 } },
        svg: { name:'SVG', wMm:30, hMm:30, props:{ svgMarkup:'', fill:doc.defaults.fillColor, stroke:doc.defaults.strokeColor, opacity:1, rotation:0 } },
      };
      const preset = presets[type]; if (!preset) return;
      p.nodes.push({ ...base, ...preset, ...extra, props: { ...base.props, ...preset.props, ...(extra.props||{}) } });
      setSelection([p.nodes[p.nodes.length - 1].id], p.nodes[p.nodes.length - 1].id);
      commitChange();
      render();
      focusCanvas();
    }

    async function addImageAt(xMm, yMm) {
      el.imageInput.click();
      const file = await new Promise((resolve) => { el.imageInput.onchange = () => resolve(el.imageInput.files?.[0] || null); });
      el.imageInput.value = '';
      if (!file) return;
      const src = await new Promise((resolve) => { const r = new FileReader(); r.onload = () => resolve(String(r.result)); r.readAsDataURL(file); });
      createPreset('image', xMm, yMm, { props: { src } });
    }

    function pagePointFromEvent(e) {
      const rect = el.page.getBoundingClientRect();
      const xPx = (e.clientX - rect.left) / doc.zoom;
      const yPx = (e.clientY - rect.top) / doc.zoom;
      const d = dims();
      return {
        xMm: clamp(gridSnap(pxToMm(xPx)), 0, d.wMm),
        yMm: clamp(gridSnap(pxToMm(yPx)), 0, d.hMm),
      };
    }

    function deleteSelectedNodes() {
      const p = activePage();
      if (!p) return;
      const ids = new Set(selectedNodes().map((n) => n.id));
      if (!ids.size) return;
      p.nodes = p.nodes.filter((n) => !ids.has(n.id));
      setPrimarySelection(null);
      commitChange();
      render();
    }

    function deleteNodeById(nodeId, fromLayer = false) {
      const p = activePage(); if (!p) return;
      const n = p.nodes.find((x)=>x.id===nodeId); if (!n) return;
      if (n.locked && !fromLayer) { showToast('Locked node cannot be deleted from canvas keys'); return; }
      if (n.locked && fromLayer) {
        const ok = window.confirm(labels.confirmDeleteLocked);
        if (!ok) return;
      }
      p.nodes = p.nodes.filter((x)=>x.id!==nodeId);
      if (selectedNodeIds.has(nodeId)) { const next = [...selectedNodeIds].filter((id) => id !== nodeId); setSelection(next, next[0] || null); }
      commitChange();
      render();
    }


    function duplicateNode(nodeId) {
      const p = activePage();
      const source = p?.nodes.find((item) => item.id === nodeId);
      if (!p || !source) return;
      const clone = structuredClone(source);
      clone.id = createId('node');
      clone.name = `${source.name} copy`;
      clone.xMm = clamp(source.xMm + 6, 0, dims().wMm - source.wMm);
      clone.yMm = clamp(source.yMm + 6, 0, dims().hMm - source.hMm);
      clone.z = (p.nodes.reduce((m, n) => Math.max(m, n.z), 0) + 1);
      clone.groupId = null;
      p.nodes.push(clone);
      setSelection([clone.id], clone.id);
      commitChange();
      render();
    }

    function copyNode(nodeId) {
      const node = activePage()?.nodes.find((item) => item.id === nodeId);
      if (!node) return;
      copiedNode = structuredClone(node);
      showToast('Node copied');
    }

    function pasteNode(targetNodeId = null) {
      if (!copiedNode) return;
      const p = activePage();
      if (!p) return;
      const source = structuredClone(copiedNode);
      source.id = createId('node');
      const target = targetNodeId ? p.nodes.find((item) => item.id === targetNodeId) : null;
      source.xMm = clamp((target?.xMm ?? source.xMm) + 8, 0, dims().wMm - source.wMm);
      source.yMm = clamp((target?.yMm ?? source.yMm) + 8, 0, dims().hMm - source.hMm);
      source.z = p.nodes.reduce((m, n) => Math.max(m, n.z), 0) + 1;
      source.groupId = null;
      p.nodes.push(source);
      setSelection([source.id], source.id);
      commitChange();
      render();
    }

    function openContextMenu(clientX, clientY, nodeId) {
      contextNodeId = nodeId;
      el.contextMenu.hidden = false;
      const menuWidth = 190;
      const menuHeight = 290;
      el.contextMenu.style.left = `${Math.min(clientX, window.innerWidth - menuWidth)}px`;
      el.contextMenu.style.top = `${Math.min(clientY, window.innerHeight - menuHeight)}px`;
    }

    function closeContextMenu() {
      contextNodeId = null;
      el.contextMenu.hidden = true;
    }

    function smartSnapSelection(movingNodes, targetBounds) {
      if (doc.grid.enabled) {
        clearGuides();
        return { dx: 0, dy: 0 };
      }
      const p = activePage();
      if (!p) return { dx: 0, dy: 0 };
      const movingIds = new Set(movingNodes.map((n) => n.id));
      const others = p.nodes.filter((n) => n.visible && !movingIds.has(n.id));
      const axesX = [targetBounds.left, targetBounds.centerX, targetBounds.right];
      const axesY = [targetBounds.top, targetBounds.centerY, targetBounds.bottom];
      let bestX = null;
      let bestY = null;
      others.forEach((node) => {
        const b = nodeBounds(node);
        [b.left, b.centerX, b.right].forEach((candidate) => {
          axesX.forEach((axis) => {
            const delta = candidate - axis;
            if (Math.abs(delta) <= SNAP_THRESHOLD_MM && (!bestX || Math.abs(delta) < Math.abs(bestX.delta))) bestX = { delta, line: candidate };
          });
        });
        [b.top, b.centerY, b.bottom].forEach((candidate) => {
          axesY.forEach((axis) => {
            const delta = candidate - axis;
            if (Math.abs(delta) <= SNAP_THRESHOLD_MM && (!bestY || Math.abs(delta) < Math.abs(bestY.delta))) bestY = { delta, line: candidate };
          });
        });
      });
      if (bestX) {
        el.guideX.style.display = 'block';
        el.guideX.style.left = `${mmToPx(bestX.line)}px`;
      } else el.guideX.style.display = 'none';
      if (bestY) {
        el.guideY.style.display = 'block';
        el.guideY.style.top = `${mmToPx(bestY.line)}px`;
      } else el.guideY.style.display = 'none';
      return { dx: bestX?.delta || 0, dy: bestY?.delta || 0 };
    }

    const DRAG_THRESHOLD_PX = 6;
    function startPointer(e) {
      const nodeEl = e.target.closest('.node'); if (!nodeEl) return;
      const n = activePage()?.nodes.find((x)=>x.id===nodeEl.dataset.id); if (!n) return;
      if (e.shiftKey) toggleNodeSelection(n.id); else setSelection([n.id], n.id);
      if (n.locked) { render(); return; }
      const handle = e.target.dataset.handle || null;
      const isContentEditable = e.target.closest('[contenteditable="true"]');
      let dragStarted = !!handle || !isContentEditable;
      const d = dims();
      const movingNodes = handle ? [n] : nodesFromSelectionOrGroup(n.id);
      const start = movingNodes.map((node) => ({ id: node.id, xMm: node.xMm, yMm: node.yMm, wMm: node.wMm, hMm: node.hMm }));
      const startBounds = selectionBounds(start);
      const s = { x:e.clientX, y:e.clientY, xMm:n.xMm, yMm:n.yMm, wMm:n.wMm, hMm:n.hMm };

      const move = (ev) => {
        if (!dragStarted) {
          const dist = Math.hypot(ev.clientX - s.x, ev.clientY - s.y);
          if (dist < DRAG_THRESHOLD_PX) return;
          dragStarted = true;
          nodeEl.querySelector('[contenteditable="true"]')?.blur();
        }
        const dx = pxToMm((ev.clientX - s.x) / doc.zoom);
        const dy = pxToMm((ev.clientY - s.y) / doc.zoom);
        if (!handle) {
          let nx = s.xMm + dx;
          let ny = s.yMm + dy;
          if (doc.grid.enabled) {
            nx = gridSnap(nx);
            ny = gridSnap(ny);
          }
          const rawBounds = { ...startBounds, left: startBounds.left + (nx - s.xMm), right: startBounds.right + (nx - s.xMm), centerX: startBounds.centerX + (nx - s.xMm), top: startBounds.top + (ny - s.yMm), bottom: startBounds.bottom + (ny - s.yMm), centerY: startBounds.centerY + (ny - s.yMm) };
          const snap = smartSnapSelection(movingNodes, rawBounds);
          const finalDx = (nx - s.xMm) + snap.dx;
          const finalDy = (ny - s.yMm) + snap.dy;
          movingNodes.forEach((node) => {
            const origin = start.find((item) => item.id === node.id);
            node.xMm = clamp(origin.xMm + finalDx, 0, d.wMm - node.wMm);
            node.yMm = clamp(origin.yMm + finalDy, 0, d.hMm - node.hMm);
          });
        } else {
          clearGuides();
          const ratio = s.wMm / s.hMm;
          const lockAspect = ev.shiftKey;
          if (handle.includes('e')) {
            n.wMm = clamp(gridSnap(s.wMm + dx), 8, d.wMm - n.xMm);
            if (lockAspect) n.hMm = clamp(gridSnap(n.wMm / ratio), 8, d.hMm - n.yMm);
          }
          if (handle.includes('s')) {
            n.hMm = clamp(gridSnap(s.hMm + dy), 8, d.hMm - n.yMm);
            if (lockAspect) n.wMm = clamp(gridSnap(n.hMm * ratio), 8, d.wMm - n.xMm);
          }
          if (handle.includes('w')) {
            const nx = clamp(gridSnap(s.xMm + dx), 0, s.xMm + s.wMm - 8);
            n.wMm = clamp(gridSnap(s.wMm - (nx - s.xMm)), 8, d.wMm);
            n.xMm = nx;
            if (lockAspect) {
              n.hMm = clamp(gridSnap(n.wMm / ratio), 8, d.hMm);
              n.yMm = clamp(s.yMm + s.hMm - n.hMm, 0, d.hMm - n.hMm);
            }
          }
          if (handle.includes('n')) {
            const ny = clamp(gridSnap(s.yMm + dy), 0, s.yMm + s.hMm - 8);
            n.hMm = clamp(gridSnap(s.hMm - (ny - s.yMm)), 8, d.hMm);
            n.yMm = ny;
            if (lockAspect) {
              n.wMm = clamp(gridSnap(n.hMm * ratio), 8, d.wMm - n.xMm);
            }
          }
        }
        renderNodes();
        renderSelectionOverlays();
      };

      const up = () => {
        window.removeEventListener('pointermove', move);
        window.removeEventListener('pointerup', up);
        clearGuides();
        if (dragStarted) commitChange();
        render();
      };
      window.addEventListener('pointermove', move);
      window.addEventListener('pointerup', up);
    }

    el.tabButtons.forEach((btn) => btn.onclick = () => switchLeftTab(btn.dataset.tab));
    el.assetSearch.oninput = () => { visibleAssetCount = ASSETS_PAGE_SIZE; renderAssets(); };
    el.assetCategoryTabs.forEach((btn) => {
      btn.onclick = () => {
        activeAssetCategory = btn.dataset.assetCategory || 'Icons';
        visibleAssetCount = ASSETS_PAGE_SIZE;
        el.assetCategoryTabs.forEach((item) => {
          const active = item === btn;
          item.classList.toggle('is-active', active);
          item.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        renderAssets();
      };
    });
    el.assetLoadMore.onclick = () => { visibleAssetCount += ASSETS_PAGE_SIZE; renderAssets(); };

    el.blockList.querySelectorAll('.block-item').forEach((b) => {
      b.ondragstart = () => { draggingBlock = b.dataset.block; };
      b.ondragend = () => { draggingBlock = null; el.dropPreview.classList.remove('show'); };
      b.onclick = () => showToast('Drag block onto page');
    });

    el.page.ondragover = (e) => {
      e.preventDefault();
      if (!draggingBlock && !draggingAssetId) return;
      const pt = pagePointFromEvent(e);
      el.dropPreview.style.left = `${mmToPx(pt.xMm)}px`;
      el.dropPreview.style.top = `${mmToPx(pt.yMm)}px`;
      el.dropPreview.classList.add('show');
    };
    el.page.ondragleave = () => el.dropPreview.classList.remove('show');
    el.page.ondrop = async (e) => {
      e.preventDefault();
      if (!draggingBlock && !draggingAssetId) return;
      const pt = pagePointFromEvent(e);
      if (draggingAssetId) {
        const asset = ASSETS.find((item) => item.id === draggingAssetId);
        if (asset) {
          createPreset('svg', pt.xMm, pt.yMm, { name: asset.name, wMm: asset.widthMm, hMm: asset.heightMm, props: { svgMarkup: asset.svgMarkup, fill: doc.defaults.fillColor, stroke: doc.defaults.strokeColor, opacity: 1, rotation: 0 } });
        }
      } else if (draggingBlock === 'image') await addImageAt(pt.xMm, pt.yMm);
      else createPreset(draggingBlock, pt.xMm, pt.yMm);
      draggingBlock = null;
      draggingAssetId = null;
      el.dropPreview.classList.remove('show');
    };
    el.stage.addEventListener('pointerdown', (e) => {
      const canPan = spacePanKeyDown && e.button === 0;
      if (!canPan) return;
      e.preventDefault();
      const startX = e.clientX;
      const startY = e.clientY;
      const wrapper = el.canvasScrollWrapper;
      const startLeft = wrapper.scrollLeft;
      const startTop = wrapper.scrollTop;
      wrapper.classList.add('is-panning');
      const onMove = (ev) => {
        wrapper.scrollLeft = startLeft - (ev.clientX - startX);
        wrapper.scrollTop = startTop - (ev.clientY - startY);
      };
      const onUp = () => {
        window.removeEventListener('pointermove', onMove);
        window.removeEventListener('pointerup', onUp);
        wrapper.classList.remove('is-panning');
      };
      window.addEventListener('pointermove', onMove);
      window.addEventListener('pointerup', onUp);
    });

    el.stage.onpointerdown = (e) => {
      if (spacePanKeyDown) return;
      if (e.target === el.stage) {
        const active = document.activeElement;
        if (active?.isContentEditable) active.blur();
        const start = pagePointFromEvent(e);
        marqueeState = { x0: start.xMm, y0: start.yMm, x1: start.xMm, y1: start.yMm, additive: e.shiftKey };
        el.marquee.hidden = false;
        const drawMarquee = () => {
          const x = Math.min(marqueeState.x0, marqueeState.x1);
          const y = Math.min(marqueeState.y0, marqueeState.y1);
          const w = Math.abs(marqueeState.x1 - marqueeState.x0);
          const h = Math.abs(marqueeState.y1 - marqueeState.y0);
          el.marquee.style.left = `${mmToPx(x)}px`;
          el.marquee.style.top = `${mmToPx(y)}px`;
          el.marquee.style.width = `${mmToPx(w)}px`;
          el.marquee.style.height = `${mmToPx(h)}px`;
        };
        drawMarquee();
        const onMove = (ev) => { const pt = pagePointFromEvent(ev); marqueeState.x1 = pt.xMm; marqueeState.y1 = pt.yMm; drawMarquee(); };
        const onUp = () => {
          window.removeEventListener('pointermove', onMove);
          window.removeEventListener('pointerup', onUp);
          const rect = { left: Math.min(marqueeState.x0, marqueeState.x1), top: Math.min(marqueeState.y0, marqueeState.y1), right: Math.max(marqueeState.x0, marqueeState.x1), bottom: Math.max(marqueeState.y0, marqueeState.y1) };
          const hits = activePage()?.nodes.filter((n) => selectionIntersects(rect, n)) || [];
          const next = marqueeState.additive ? [...new Set([...selectedNodeIds, ...hits.map((n) => n.id)])] : hits.map((n) => n.id);
          setSelection(next, hits[hits.length - 1]?.id || null);
          el.marquee.hidden = true;
          marqueeState = null;
          render();
        };
        window.addEventListener('pointermove', onMove);
        window.addEventListener('pointerup', onUp);
        return;
      }
      if (e.target.closest('[data-add-item]')) return;
      startPointer(e);
    };

    el.arrangeToolbar.querySelectorAll('[data-arrange]').forEach((btn) => {
      btn.onclick = () => applyArrange(btn.dataset.arrange);
    });
    el.copyStyleBtn.onclick = () => copyStyle();
    el.pasteStyleBtn.onclick = () => pasteStyle();

    const applyInspector = (fn) => { const n = activeNode(); if (!n || n.locked || selectedNodeIds.size > 1) return; fn(n); commitChange(); render(); };
    el.insX.onchange = () => applyInspector((n)=>n.xMm = gridSnap(Number(el.insX.value) || 0));
    el.insY.onchange = () => applyInspector((n)=>n.yMm = gridSnap(Number(el.insY.value) || 0));
    el.insW.onchange = () => applyInspector((n)=>n.wMm = Math.max(8, Number(el.insW.value) || 8));
    el.insH.onchange = () => applyInspector((n)=>n.hMm = Math.max(8, Number(el.insH.value) || 8));
    el.insFontFamily.onchange = () => applyInspector((n)=>n.props.fontFamily = el.insFontFamily.value);
    el.insFontSize.onchange = () => applyInspector((n)=>n.props.fontSize = Math.max(8, Number(el.insFontSize.value) || 14));
    el.insFontWeight.onchange = () => applyInspector((n)=>n.props.fontWeight = Number(el.insFontWeight.value));
    el.insItalic.onchange = () => applyInspector((n)=>n.props.italic = el.insItalic.checked);
    el.insAlign.onchange = () => applyInspector((n)=>n.props.align = el.insAlign.value);
    el.insTextColor.onchange = () => { addRecentColor(el.insTextColor.value); applyInspector((n)=>n.props.color = el.insTextColor.value); };
    el.insFill.onchange = () => { addRecentColor(el.insFill.value); applyInspector((n)=>n.props.fill = el.insFill.value); };
    el.insStroke.onchange = () => { addRecentColor(el.insStroke.value); applyInspector((n)=>n.props.stroke = el.insStroke.value); };
    el.insSvgFill.onchange = () => { addRecentColor(el.insSvgFill.value); applyInspector((n)=>n.props.fill = el.insSvgFill.value); };
    el.insSvgStroke.onchange = () => { addRecentColor(el.insSvgStroke.value); applyInspector((n)=>n.props.stroke = el.insSvgStroke.value); };
    el.insStrokeWidth.onchange = () => applyInspector((n)=>n.props.strokeWidth = Math.max(0.5, Number(el.insStrokeWidth.value) || 1));
    el.insRadius.onchange = () => applyInspector((n)=>n.props.radius = Math.max(0, Number(el.insRadius.value) || 0));
    el.insThickness.onchange = () => applyInspector((n)=>n.props.thickness = Math.max(1, Number(el.insThickness.value) || 1));
    el.insColor.onchange = () => { addRecentColor(el.insColor.value); applyInspector((n)=>n.props.color = el.insColor.value); };
    el.insObjectFit.onchange = () => applyInspector((n)=>n.props.objectFit = el.insObjectFit.value);
    el.insOpacity.onchange = () => applyInspector((n)=>n.props.opacity = Number(el.insOpacity.value));
    el.insShadow.onchange = () => applyInspector((n)=>n.props.boxShadow = el.insShadow.checked ? '0 2px 8px rgba(0,0,0,0.15)' : '');
    el.insRotation.onchange = () => applyInspector((n)=>n.props.rotation = Number(el.insRotation.value));
    el.insLineHeight.onchange = () => applyInspector((n)=>n.props.lineHeight = Number(el.insLineHeight.value));
    el.insListLineHeight.onchange = () => applyInspector((n)=>n.props.lineHeight = Number(el.insListLineHeight.value));
    el.insListStyle.onchange = () => applyInspector((n)=>n.props.listStyle = el.insListStyle.value);
    el.insTableRows.onchange = () => applyInspector((n)=>n.props.rows = clamp(Math.round(Number(el.insTableRows.value) || 2), 2, 10));
    el.insTableCols.onchange = () => applyInspector((n)=>n.props.cols = clamp(Math.round(Number(el.insTableCols.value) || 2), 2, 10));

    function applyStylePreset(target = 'selection') {
      const preset = STYLE_PRESETS[doc.pendingStylePreset || 'minimal'];
      const targetNodes = target === 'all'
        ? activePage()?.nodes || []
        : selectedNodes();
      if (!targetNodes.length) return;
      doc.defaults = { ...preset.defaults };
      targetNodes.forEach((n) => {
        if (["text","heading","paragraph","datelabel"].includes(n.type)) {
          n.props.fontFamily = preset.defaults.fontFamily;
          n.props.color = preset.defaults.textColor;
        }
        if (["box","highlight","roundedrect","circle","svg"].includes(n.type)) {
          n.props.fill = preset.defaults.fillColor;
          n.props.stroke = preset.defaults.strokeColor;
          if (n.type !== 'circle') n.props.radius = preset.defaults.radius;
        }
        if (["line","divider"].includes(n.type)) n.props.color = preset.defaults.strokeColor;
      });
      commitChange();
      render();
      showToast(`${preset.name} preset applied`);
    }

    function zMove(mode) {
      const p = activePage(); const n = activeNode(); if (!p || !n) return;
      const arr = [...p.nodes].sort((a,b)=>a.z-b.z);
      const i = arr.findIndex((x)=>x.id===n.id);
      if (mode === 'front') { arr.splice(i,1); arr.push(n); }
      if (mode === 'back') { arr.splice(i,1); arr.unshift(n); }
      if (mode === 'forward' && i < arr.length - 1) [arr[i], arr[i+1]] = [arr[i+1], arr[i]];
      if (mode === 'backward' && i > 0) [arr[i], arr[i-1]] = [arr[i-1], arr[i]];
      arr.forEach((node, idx)=>node.z = idx + 1);
      commitChange(); render();
    }
    el.zFront.onclick = () => zMove('front');
    el.zBack.onclick = () => zMove('back');
    el.zForward.onclick = () => zMove('forward');
    el.zBackward.onclick = () => zMove('backward');

    document.querySelectorAll('[data-size]').forEach((b)=>b.onclick = () => { doc.pageSize = b.dataset.size; commitChange(); render(); });
    document.querySelectorAll('[data-orientation]').forEach((b)=>b.onclick = () => { doc.orientation = b.dataset.orientation; commitChange(); render(); });
    el.zoom.onchange = () => {
      const val = el.zoom.value;
      if (val === 'fit') {
        doc.zoom = clamp((el.canvasScrollWrapper.clientWidth - 40) / mmToPx(dims().wMm), 0.25, 1.5);
      } else if (val === 'fitSelection') {
        const box = selectionBounds();
        if (box && selectedNodeIds.size > 0) {
          const pad = 15;
          const cw = el.canvasScrollWrapper.clientWidth;
          const ch = el.canvasScrollWrapper.clientHeight;
          const zoomW = (cw - 40) / (mmToPx(box.width + pad * 2));
          const zoomH = (ch - 40) / (mmToPx(box.height + pad * 2));
          doc.zoom = clamp(Math.min(zoomW, zoomH), 0.25, 2);
          const contentW = mmToPx(dims().wMm) * doc.zoom;
          const contentH = mmToPx(dims().hMm) * doc.zoom;
          el.canvasScrollWrapper.scrollLeft = Math.max(0, Math.min(contentW - cw, mmToPx(box.centerX) * doc.zoom - cw / 2));
          el.canvasScrollWrapper.scrollTop = Math.max(0, Math.min(contentH - ch, mmToPx(box.centerY) * doc.zoom - ch / 2));
        }
        el.zoom.value = String(doc.zoom);
      } else {
        doc.zoom = Number(val);
      }
      commitChange();
      render();
    };
    el.gridToggle.onchange = () => { doc.grid.enabled = el.gridToggle.checked; commitChange(); render(); };
    el.rulerToggle.onchange = () => { doc.rulerOn = el.rulerToggle.checked; commitChange(); render(); };
    el.safeAreaToggle.onchange = () => { doc.safeAreaOn = el.safeAreaToggle.checked; commitChange(); render(); };
    el.gridStep.onchange = () => { doc.grid.stepMm = Number(el.gridStep.value); commitChange(); render(); };
    el.themeWorkspaceColor.onchange = () => { addRecentColor(el.themeWorkspaceColor.value); doc.workspaceBg = el.themeWorkspaceColor.value; commitChange(); render(); };
    el.themeWorkspacePattern.onchange = () => { doc.workspacePatternOn = el.themeWorkspacePattern.checked; commitChange(); render(); };
    el.themePageColor.onchange = () => { addRecentColor(el.themePageColor.value); doc.pageBg = el.themePageColor.value; commitChange(); render(); };
    el.themeDefaultText.onchange = () => { addRecentColor(el.themeDefaultText.value); doc.defaults.textColor = el.themeDefaultText.value; commitChange(); render(); };
    el.themeDefaultFill.onchange = () => { addRecentColor(el.themeDefaultFill.value); doc.defaults.fillColor = el.themeDefaultFill.value; commitChange(); render(); };
    el.themeDefaultStroke.onchange = () => { addRecentColor(el.themeDefaultStroke.value); doc.defaults.strokeColor = el.themeDefaultStroke.value; commitChange(); render(); };
    el.themeDefaultRadius.onchange = () => { doc.defaults.radius = clamp(Number(el.themeDefaultRadius.value) || 0, 0, 80); commitChange(); render(); };
    el.themeSubtabs.forEach((btn) => {
      btn.onclick = () => switchThemeSubtab(btn.dataset.themeSubtab || 'page');
    });
    el.presetApplySelection.onclick = () => applyStylePreset('selection');
    el.presetApplyAll.onclick = () => applyStylePreset('all');

    el.addPage.onclick = () => { const p = { id:createId('page'), name:`Page ${doc.pages.length+1}`, nodes:[] }; doc.pages.push(p); doc.activePageId = p.id; setPrimarySelection(null); commitChange(); render(); };
    el.dupPage.onclick = () => { const p = activePage(); if(!p) return; const c=structuredClone(p); c.id=createId('page'); c.name=`Page ${doc.pages.length+1}`; c.nodes.forEach((n)=>n.id=createId('node')); doc.pages.push(c); doc.activePageId=c.id; setPrimarySelection(null); commitChange(); render(); };
    el.delPage.onclick = () => { if(doc.pages.length<=1) return; doc.pages=doc.pages.filter((p)=>p.id!==doc.activePageId); doc.activePageId=doc.pages[0].id; setPrimarySelection(null); commitChange(); render(); };

    el.save.onclick = () => { saveToLocal(doc); captureRecentSnapshot(); dirty = false; setSaveIndicator(); showToast(labels.toastSaved); closeTransientOverlays(); };
    el.load.onclick = () => { const loaded = loadFromLocal(); if(!loaded) return; loadDoc(loaded); showToast(labels.toastLoaded); closeTransientOverlays(); };
    el.exportPdf.onclick = async () => { try { closeTransientOverlays(); showToast(labels.toastPdfGenerating); const blob = await exportDocToPDF(doc); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = `printforge-${(doc.meta?.projectName || 'export').replace(/[^a-z0-9-_]/gi, '-')}-${Date.now()}.pdf`; a.click(); URL.revokeObjectURL(url); showToast(labels.toastPdfDone); } catch (err) { showToast(labels.toastPdfFailed); console.error(err); } };
    el.exportPng.onclick = async () => { try { closeTransientOverlays(); const pageId = doc.activePageId || doc.pages[0]?.id; if (!pageId) return; const blob = await exportPageToPng(doc, pageId); const url = URL.createObjectURL(blob); const a = document.createElement('a'); a.href = url; a.download = `printforge-page-${Date.now()}.png`; a.click(); URL.revokeObjectURL(url); showToast(labels.toastPngDone); } catch (err) { showToast(labels.toastPngFailed); console.error(err); } };
    el.ex.onclick = () => { exportJSON(doc); closeTransientOverlays(); };
    el.im.onclick = () => { el.importInput.click(); closeTransientOverlays(); };

    function buildPrintHTML(d) {
      const dims = pageDimensionsMm(d.pageSize, d.orientation);
      const pxPerMm = 3.7795275591;
      const def = d.defaults || {};
      const pageStyle = `width:${dims.wMm}mm;height:${dims.hMm}mm;background:${d.pageBg||'#fff'};position:relative;page-break-after:always;margin:0 auto 12px;box-shadow:0 2px 8px rgba(0,0,0,.1);overflow:hidden;`;
      let html = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Print</title><style>body{margin:0;padding:12px;background:#666;} .page{${pageStyle}} .node{position:absolute;font-family:Inter,sans-serif;} .p-text{white-space:pre-wrap;word-break:break-word;} .p-box{box-sizing:border-box;} .p-table{display:grid;border:1px solid #94a3b8;} .p-table>div{border:1px solid #94a3b8;} @media print{body{background:#fff;padding:0;} .page{page-break-after:always;box-shadow:none;margin:0;} .page:last-child{page-break-after:auto;}}</style></head><body>`;
      d.pages.forEach((pg) => {
        html += `<div class="page" style="${pageStyle}">`;
        [...pg.nodes].sort((a,b)=>a.z-b.z).forEach((n) => {
          if (!n.visible) return;
          const left = n.xMm; const top = n.yMm; const w = n.wMm; const h = n.hMm;
          const pos = `left:${left}mm;top:${top}mm;width:${w}mm;height:${h}mm;`;
          let inner = '';
          if (['text','heading','paragraph','datelabel'].includes(n.type)) {
            const fs = n.props.fontSize||14; const c = n.props.color||def.textColor||'#111'; const align = n.props.align||'left';
            inner = `<div class="p-text" style="font-size:${fs}px;color:${c};text-align:${align};line-height:${(n.props.lineHeight||1.3)};margin:0;">${(n.props.text||'').replace(/</g,'&lt;').replace(/\n/g,'<br>')}</div>`;
          } else if (['box','highlight','roundedrect'].includes(n.type)) {
            const fill = n.props.fill||def.fillColor||'#e2e8f0'; const stroke = n.props.stroke||def.strokeColor||'#94a3b8'; const r = n.props.radius||0;
            inner = `<div class="p-box" style="width:100%;height:100%;background:${fill};border:1px solid ${stroke};border-radius:${r}px;"></div>`;
          } else if (n.type === 'circle') {
            const fill = n.props.fill||def.fillColor; const stroke = n.props.stroke||def.strokeColor;
            inner = `<div class="p-box" style="width:100%;height:100%;background:${fill};border:1px solid ${stroke};border-radius:50%;"></div>`;
          } else if (['line','divider'].includes(n.type)) {
            const th = n.props.thickness||2; const col = n.props.color||def.strokeColor||'#334155';
            inner = `<div style="position:absolute;left:0;top:50%;margin-top:-${th/2}px;height:${th}px;width:100%;background:${col};"></div>`;
          } else if (n.type === 'checkbox') {
            inner = `<span style="font-size:12px;">${n.props.checked?'☑':'☐'} ${(n.props.text||'Task').replace(/</g,'&lt;')}</span>`;
          } else if (n.type === 'checklist' || n.type === 'bulletlist') {
            const items = (n.props.items||['Item']).map((it)=>`<div>${(n.props.listStyle==='checkbox'?'☐ ':'• ')}${(it||'').replace(/</g,'&lt;')}</div>`).join('');
            inner = `<div style="font-size:12px;line-height:1.4;">${items}</div>`;
          } else if (n.type === 'table') {
            const rows = n.props.rows||3; const cols = n.props.cols||3;
            inner = `<div class="p-table" style="width:100%;height:100%;grid-template-columns:repeat(${cols},1fr);grid-template-rows:repeat(${rows},1fr);">${Array(rows*cols).fill('<div></div>').join('')}</div>`;
          } else if (n.type === 'image' && n.props.src) {
            inner = `<img src="${n.props.src}" alt="" style="width:100%;height:100%;object-fit:${n.props.objectFit||'contain'};display:block;">`;
          } else { inner = '<div style="width:100%;height:100%;background:#f1f5f9;"></div>'; }
          html += `<div class="node" style="${pos}">${inner}</div>`;
        });
        html += '</div>';
      });
      html += '</body></html>';
      return html;
    }
    el.printPreview.onclick = () => { const w = window.open('', '_blank'); if (!w) return; w.document.write(buildPrintHTML(doc)); w.document.close(); closeTransientOverlays(); };
    el.printBtn.onclick = () => { const w = window.open('', '_blank'); if (!w) return; w.document.write(buildPrintHTML(doc)); w.document.close(); setTimeout(() => { w.focus(); w.print(); }, 300); closeTransientOverlays(); };
    el.importInput.onchange = async () => { const f=el.importInput.files?.[0]; if(!f) return; try{ const imported = await importJSON(f); loadDoc(imported); dirty = true; setSaveIndicator(); autosaveSchedule(); showToast(labels.toastImported); } catch { showToast(labels.toastInvalidJson); } el.importInput.value=''; };
    el.delBtn.onclick = () => { if (selectedNodeIds.size > 1) deleteSelectedNodes(); else if (selectedNodeId) deleteNodeById(selectedNodeId, false); };

    el.newProjectBtn.onclick = () => { captureRecentSnapshot(); openTemplateModal(); closeTransientOverlays(); };
    el.templateCloseBtn.onclick = () => closeTemplateModal();
    el.templateBlankBtn.onclick = () => applyTemplateSelection(null);
    el.templateSearch.oninput = () => renderTemplateCards();
    el.templateCategory.onchange = () => renderTemplateCards();
    el.templateHideToggle.onchange = () => localStorage.setItem(TEMPLATE_HIDE_KEY, el.templateHideToggle.checked ? '1' : '0');
    el.templateModal.addEventListener('click', (event) => {
      if (event.target === el.templateModal) closeTemplateModal();
    });

    const shortcutsOverlay = document.getElementById('shortcuts-overlay');
    const shortcutsClose = document.getElementById('shortcuts-close');
    document.getElementById('shortcuts-btn').onclick = () => { if (shortcutsOverlay) shortcutsOverlay.hidden = false; };
    if (shortcutsClose) shortcutsClose.onclick = () => { if (shortcutsOverlay) shortcutsOverlay.hidden = true; };
    if (shortcutsOverlay) shortcutsOverlay.onclick = (ev) => { if (ev.target === shortcutsOverlay) shortcutsOverlay.hidden = true; };
    const tipsOverlay = document.getElementById('tips-overlay');
    const tipsClose = document.getElementById('tips-close');
    document.getElementById('tips-btn').onclick = () => { if (tipsOverlay) tipsOverlay.hidden = false; };
    if (tipsClose) tipsClose.onclick = () => { if (tipsOverlay) tipsOverlay.hidden = true; };
    if (tipsOverlay) tipsOverlay.onclick = (ev) => { if (ev.target === tipsOverlay) tipsOverlay.hidden = true; };

    el.duplicateProjectBtn.onclick = () => {
      const duplicate = structuredClone(doc);
      duplicate.meta.projectName = `${doc.meta.projectName || labels.untitledProject} copy`;
      loadDoc(duplicate);
      commitChange();
      showToast(labels.toastProjectDuplicated);
      closeTransientOverlays();
    };
    el.clearProjectBtn.onclick = () => {
      const ok = window.confirm(labels.confirmClearProject);
      if (!ok) return;
      captureRecentSnapshot();
      loadDoc(defaultDoc());
      showToast(labels.toastProjectCleared);
      closeTransientOverlays();
    };
    el.projectName.onchange = () => {
      doc.meta.projectName = (el.projectName.value || labels.untitledProject).trim() || labels.untitledProject;
      commitChange();
      render();
    };


    el.contextMenu.addEventListener('click', (event) => {
      const action = event.target.closest('[data-context-action]')?.dataset.contextAction;
      if (!action || !contextNodeId) return;
      if (action === 'duplicate') duplicateNode(contextNodeId);
      if (action === 'delete') deleteNodeById(contextNodeId, true);
      if (action === 'front') { setSelection([contextNodeId], contextNodeId); zMove('front'); }
      if (action === 'back') { setSelection([contextNodeId], contextNodeId); zMove('back'); }
      if (action === 'lock') {
        const node = activePage()?.nodes.find((item) => item.id === contextNodeId);
        if (node) { node.locked = !node.locked; commitChange(); render(); }
      }
      if (action === 'visibility') {
        const node = activePage()?.nodes.find((item) => item.id === contextNodeId);
        if (node) { node.visible = !node.visible; commitChange(); render(); }
      }
      if (action === 'copy') copyNode(contextNodeId);
      if (action === 'paste') pasteNode(contextNodeId);
      closeContextMenu();
    });

    document.addEventListener('pointerdown', (event) => {
      if (el.contextMenu.hidden) return;
      if (!event.target.closest('#context-menu')) closeContextMenu();
    });

    window.addEventListener('keydown', (e) => {
      const active = document.activeElement;
      const typing = active && (active.matches('input,textarea,select') || active.isContentEditable);
      const mod = e.ctrlKey || e.metaKey;

      if (typing && mod && e.key.toLowerCase() === 'z') return;

      if (mod && e.key.toLowerCase() === 'z') {
        e.preventDefault();
        if (e.shiftKey) {
          if (!redoStack.length) return;
          const next = redoStack.pop();
          undoStack.push(structuredClone(next));
          doc = structuredClone(next);
        } else {
          if (undoStack.length <= 1) return;
          const current = undoStack.pop();
          redoStack.push(structuredClone(current));
          doc = structuredClone(undoStack[undoStack.length - 1]);
        }
        setPrimarySelection(null);
        dirty = true;
        setSaveIndicator();
        autosaveSchedule();
        render();
        return;
      }

      if (mod && e.key.toLowerCase() === 'g') {
        e.preventDefault();
        if (e.shiftKey) ungroupSelection();
        else groupSelection();
        return;
      }

      if (mod && e.key.toLowerCase() === 'd') {
        e.preventDefault();
        if (selectedNodeIds.size) {
          const ids = [...selectedNodeIds];
          ids.forEach((id) => duplicateNode(id));
          if (ids.length === 1) showToast(labels.contextDuplicate);
        }
        return;
      }

      if (e.key === 'Escape') {
        const shortcutsEl = document.getElementById('shortcuts-overlay');
        if (shortcutsEl && !shortcutsEl.hidden) { shortcutsEl.hidden = true; focusCanvas(); return; }
        const tipsEl = document.getElementById('tips-overlay');
        if (tipsEl && !tipsEl.hidden) { tipsEl.hidden = true; focusCanvas(); return; }
        if (!el.templateModal.hidden) { closeTemplateModal(); focusCanvas(); return; }
        if (!el.contextMenu.hidden) { closeContextMenu(); focusCanvas(); return; }
        const hadOverlay = el.fileMenu.open || el.toast.classList.contains('show');
        closeTransientOverlays();
        if (!hadOverlay) {
          setPrimarySelection(null);
          render();
        }
        focusCanvas();
        return;
      }
      if (!typing && e.code === 'Space') {
        spacePanKeyDown = true;
        e.preventDefault();
      }
      if (typing) return;
      if ((e.key === 'Delete' || e.key === 'Backspace') && selectedNodeIds.size) {
        e.preventDefault();
        deleteSelectedNodes();
      }
    });

    window.addEventListener('keyup', (e) => {
      if (e.code === 'Space') spacePanKeyDown = false;
    });

    if (import.meta.env.DEV) {
      const validationResults = validateTemplates();
      const failed = validationResults.filter((item) => !item.ok);
      console.info('[templates] validation summary', { total: validationResults.length, failed: failed.length });
      if (failed.length) console.warn('[templates] validation failures', failed);
    }

    renderAssets();
    switchThemeSubtab('page');
    renderRecentProjects();
    render();
    if (localStorage.getItem(TEMPLATE_HIDE_KEY) !== '1') openTemplateModal();
    focusCanvas();
  </script>
</BaseLayout>
